---
import { Search as SearchIcon } from '@lucide/astro';
import type { ArticleSearchEntry } from '../lib/articleSearchIndex';

interface Props {
  articles: ArticleSearchEntry[];
  listId?: string;
  statusId?: string;
  emptyId?: string;
}

const {
  articles,
  listId = 'article-list',
  statusId = 'article-search-status',
  emptyId = 'article-search-empty',
} = Astro.props;

const totalCount = articles.length;
const searchIndexJson = JSON.stringify(articles);
const configId = `article-search-config-${listId}`;
---

<div
  class="mb-6"
  data-article-search-root
  data-list-id={listId}
  data-status-id={statusId}
  data-empty-id={emptyId}
  data-total-count={totalCount}
>
  <script id={configId} type="application/json" set:html={searchIndexJson}></script>

  <label for="article-search-input" class="sr-only">Search articles</label>
  <div class="relative">
    <SearchIcon class="w-5 h-5 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" aria-hidden="true" />
    <input
      type="search"
      id="article-search-input"
      class="w-full pl-10 pr-4 py-3 rounded-lg border border-emerald-900/15 hover:border-emerald-900/30 transition-colors bg-white text-slate-900 placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent"
      placeholder="Search articles…"
      autocomplete="off"
      aria-controls={listId}
      aria-describedby={`${statusId} ${emptyId}`}
    />
  </div>
  <p id={statusId} class="mt-3 text-sm text-slate-500" aria-live="polite">
    Showing all {totalCount} articles.
  </p>
  <p
    id={emptyId}
    class="mt-3 text-sm text-slate-500 hidden"
    role="status"
  >
    No articles match your search. Try a different keyword.
  </p>
</div>
