---
import BookingButton from './BookingButton.astro';

export interface Props {
  title: string;
  description: string;
  source: string;
}

const { title, description, source } = Astro.props;
---

<section class="bg-emerald-950 py-16 lg:py-20">
  <div class="section-shell text-center">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-5 text-3xl font-serif font-medium text-white sm:text-4xl">{title}</h2>
      <p class="mb-8 text-lg leading-relaxed text-white/85">{description}</p>
      <BookingButton text="Book Online" variant="hero" size="lg" source={source} />
    </div>
  </div>
</section>
