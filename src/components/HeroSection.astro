---
export interface Props {
  title: string;
  centered?: boolean;
  compact?: boolean;
  textOnly?: boolean;
  image?: {
    src: string;
    alt: string;
    aspect?: 'video' | 'square';
  };
  video?: {
    src: string;
    title: string;
  };
}

const { title, centered = false, compact = false, textOnly = false, image, video } = Astro.props;
const hasMedia = image || video;
const currentPath = Astro.url.pathname;
const hasBreadcrumbSlot = Astro.slots.has('breadcrumb');
const servicePagePaths = [
  '/acupuncture/',
  '/chelation-therapy/',
  '/clinical-nutrition/',
  '/digestive-health-testing/',
  '/glutathione/',
  '/herbal-medicine/',
  '/hormone-testing/',
  '/iv-therapy/',
  '/iv-vitamin-c/',
  '/l-carnitine/',
  '/lab-testing/',
  '/microcurrent-therapy/',
  '/myers-cocktail-intravenous-nutrients/',
  '/nad-therapy/',
  '/neural-prolotherapy-pain/',
  '/nutrient-testing/',
  '/prolotherapy/',
  '/prolotherapy-for-arthritis/',
  '/prolotherapy-for-back-pain/',
  '/prolotherapy-for-osgood-schlatter/',
  '/prolotherapy-for-tendon-injuries/',
  '/specialized-testing/',
  '/sports-medicine/',
  '/thyroid-testing/',
  '/trace-minerals/',
  '/wellness-blood-work/',
];
const conditionPagePaths = [
  '/achilles-tendinitis/',
  '/carpal-tunnel-syndrome/',
  '/chronic-fatigue-syndrome/',
  '/fibromyalgia/',
  '/frozen-shoulder/',
  '/golfers-elbow/',
  '/herniated-disc/',
  '/low-back-pain/',
  '/migraine-headache/',
  '/osteoarthritis/',
  '/plantar-fasciitis/',
  '/rotator-cuff-shoulder-impingement/',
  '/runners-knee/',
  '/si-joint-dysfunction/',
  '/tennis-elbow/',
  '/tmj-dysfunction/',
  '/whiplash-neck-pain/',
];
const labTestingPagePaths = [
  '/digestive-health-testing/',
  '/hormone-testing/',
  '/nutrient-testing/',
  '/specialized-testing/',
  '/thyroid-testing/',
  '/wellness-blood-work/',
];
const defaultBreadcrumb = labTestingPagePaths.includes(currentPath)
  ? { href: '/lab-testing/', label: 'Lab Testing' }
  : servicePagePaths.includes(currentPath)
    ? { href: '/services/', label: 'Services' }
    : conditionPagePaths.includes(currentPath)
      ? { href: '/conditions/', label: 'Conditions' }
      : null;

// Padding classes based on compact prop
const sectionPadding = compact
  ? "pb-16 lg:pb-24"
  : "pb-24 lg:pb-32";

// Image dimensions based on aspect ratio
const imageAspect = image?.aspect || 'video';
const imageClasses = imageAspect === 'square'
  ? "aspect-square"
  : "aspect-video";
const imageDimensions = imageAspect === 'square'
  ? { width: 800, height: 800 }
  : { width: 1280, height: 720 };
---

<section class={`bg-emerald-950 -mt-24 pt-32 lg:pt-44 ${sectionPadding}`}>
  <div class="section-shell">
    {centered ? (
      <div class="text-center max-w-4xl mx-auto space-y-6">
        {hasBreadcrumbSlot ? (
          <slot name="breadcrumb" />
        ) : defaultBreadcrumb && (
          <nav class="text-emerald-300 text-sm mb-4" aria-label="Breadcrumb">
            <a href={defaultBreadcrumb.href} class="hover:text-white transition-colors">{defaultBreadcrumb.label}</a>
            <span class="mx-2" aria-hidden="true">/</span>
            <span class="text-white">{title}</span>
          </nav>
        )}
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-serif font-medium text-white mb-6 tracking-tight">{title}</h1>
        <div class="text-lg sm:text-xl text-emerald-100 mb-8 leading-relaxed font-light">
          <slot />
        </div>
        <slot name="cta" />
      </div>
    ) : textOnly ? (
      <div class="max-w-4xl">
        {hasBreadcrumbSlot ? (
          <slot name="breadcrumb" />
        ) : defaultBreadcrumb && (
          <nav class="text-emerald-300 text-sm mb-4" aria-label="Breadcrumb">
            <a href={defaultBreadcrumb.href} class="hover:text-white transition-colors">{defaultBreadcrumb.label}</a>
            <span class="mx-2" aria-hidden="true">/</span>
            <span class="text-white">{title}</span>
          </nav>
        )}
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-serif font-medium text-white tracking-tight mb-6">{title}</h1>
        <div class="text-lg sm:text-xl text-white/90 leading-relaxed font-light space-y-4 mb-8">
          <slot />
        </div>
        <slot name="cta" />
      </div>
    ) : (
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-6">
          {hasBreadcrumbSlot ? (
            <slot name="breadcrumb" />
          ) : defaultBreadcrumb && (
            <nav class="text-emerald-300 text-sm mb-4" aria-label="Breadcrumb">
              <a href={defaultBreadcrumb.href} class="hover:text-white transition-colors">{defaultBreadcrumb.label}</a>
              <span class="mx-2" aria-hidden="true">/</span>
              <span class="text-white">{title}</span>
            </nav>
          )}
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-serif font-medium text-white tracking-tight">{title}</h1>
          <div class="text-lg sm:text-xl text-white/90 leading-relaxed font-light space-y-4">
            <slot />
          </div>
          <slot name="cta" />
        </div>
        {image && (
          <div class={`rounded-2xl overflow-hidden shadow-2xl ${imageAspect === 'square' ? 'aspect-square' : ''}`}>
            <img
              src={image.src}
              alt={image.alt}
              class={`w-full h-full object-cover ${imageClasses}`}
              width={imageDimensions.width}
              height={imageDimensions.height}
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>
        )}
        {video && (
          <div class="aspect-video rounded-2xl overflow-hidden shadow-2xl">
            <iframe
              src={video.src}
              title={video.title}
              class="w-full h-full"
              style="border: 0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen>
            </iframe>
          </div>
        )}
        {!hasMedia && (
          <slot name="media" />
        )}
      </div>
    )}
  </div>
</section>
