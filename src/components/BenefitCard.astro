---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="group h-full rounded-2xl border border-emerald-100 bg-white p-6 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:border-emerald-200 hover:shadow-md sm:p-8">
  <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-50 text-emerald-700 ring-1 ring-emerald-100 transition-colors group-hover:bg-emerald-100">
    <slot name="icon" />
  </div>
  <h3 class="mb-3 text-xl font-serif font-medium text-emerald-950">{title}</h3>
  <div class="text-slate-600">
    <slot />
  </div>
</div>
