---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CTAButton from '../components/CTAButton.astro';
import FAQSection from '../components/FAQSection.astro';
import { ClipboardCheck, TestTubes, Clock, Sparkles, ChevronRight } from '@lucide/astro';

const benefits = [
  {
    title: 'No Family-Doctor Requisition',
    description: 'Dr. MacLeod can order appropriate testing for patients of the practice.',
    icon: ClipboardCheck,
  },
  {
    title: 'Broad Testing Options',
    description: 'Options range from general wellness blood work to selected specialized panels.',
    icon: TestTubes,
  },
  {
    title: 'In-Office Collection',
    description: 'Blood collection is performed in the clinic for tests available through the practice.',
    icon: Clock,
  },
  {
    title: 'Clinical Interpretation',
    description: 'Results are reviewed in the context of your symptoms, history and other clinical information.',
    icon: Sparkles,
  },
];

const testingOptions = [
  {
    title: 'Complete Thyroid Panel',
    description: 'Go beyond standard TSH testing with Free T3, Free T4, Reverse T3 and thyroid antibodies.',
    href: '/thyroid-testing/',
    image: '/images/lab-testing/thyroid-panel.webp',
    alt: 'Thyroid gland anatomy illustration',
  },
  {
    title: 'Hormone Testing',
    description: 'Assessment of sex hormones, cortisol and DHEA using blood, saliva or urine when appropriate.',
    href: '/hormone-testing/',
    image: '/images/lab-testing/hormone-testing.webp',
    alt: 'Hormone testing blood vials',
  },
  {
    title: 'Nutrient Status',
    description: 'Assess vitamin D, B12, iron, magnesium, zinc and other nutrients that may affect health.',
    href: '/nutrient-testing/',
    image: '/images/lab-testing/nutrient-status.webp',
    alt: 'Nutritious foods associated with nutrient status',
  },
  {
    title: 'Wellness Baseline',
    description: 'Comprehensive screening that may include blood counts, metabolic markers, lipids and blood sugar.',
    href: '/wellness-blood-work/',
    image: '/images/lab-testing/in-office-wellness-blood-work.webp',
    alt: 'Dr. Colin MacLeod preparing a patient for in-office blood work',
  },
  {
    title: 'Digestive Health',
    description: 'Stool analysis and other assessments selected according to symptoms and clinical history.',
    href: '/digestive-health-testing/',
    image: '/images/lab-testing/digestive-health.webp',
    alt: 'Digestive system illustration',
  },
  {
    title: 'Specialized Testing',
    description: 'Selected assessments for complex cases, including heavy metals, organic acids and other panels.',
    href: '/specialized-testing/',
    image: '/images/lab-testing/specialized-testing.webp',
    alt: 'Blood draw preparation for specialized testing',
  },
];

const steps = [
  ['1', 'Initial Consultation', 'Discuss your health concerns, history and goals with Dr. MacLeod.'],
  ['2', 'Select Testing', 'Choose clinically relevant tests and review the expected costs before ordering.'],
  ['3', 'Sample Collection', 'Complete blood collection in the clinic with preparation instructions provided in advance.'],
  ['4', 'Review Results', 'Review the complete pattern and determine practical recommendations or next steps.'],
];

const faqs = [
  { question: "Do I need a doctor's referral for blood work?", answer: "<p>No. You can access comprehensive blood work without a family doctor's requisition. This can be helpful if you do not have a family doctor or want to discuss testing that is not routinely ordered.</p>" },
  { question: 'Is private blood work covered by MSI?', answer: '<p>Testing ordered through a naturopathic doctor is not covered by MSI. Many extended health insurance plans cover naturopathic consultations, while laboratory costs are generally paid out of pocket. Check your individual plan for details.</p>' },
  { question: 'Where is the blood draw performed?', answer: "<p>Dr. MacLeod performs blood collection in the clinic, so you generally will not need to visit a separate laboratory.</p>" },
  { question: 'How long until I get my results?', answer: '<p>Many standard blood tests return within 5–10 business days. Specialized tests such as comprehensive stool analysis or hormone panels may take 2–3 weeks. A follow-up is arranged once the relevant results are available.</p>' },
  { question: 'Do I need to fast before blood tests?', answer: '<p>Some tests require fasting and others do not. You will receive preparation instructions for the tests being ordered.</p>' },
];
---

<BaseLayout
  title="Private Blood Testing and Lab Testing in Halifax"
  description="Private blood work and lab testing in Halifax. Hormone panels, thyroid, nutrient assessments and more. No family doctor requisition required."
  focusKeyword="private blood work Halifax"
>
  <HeroSection
    title="Laboratory Testing"
    compact
    image={{
      src: '/images/lab-testing/in-office-blood-draw.webp',
      alt: 'Dr. Colin MacLeod performing an in-office blood draw',
      aspect: 'square',
    }}
  >
    <p>Get the blood work and laboratory testing you need without a family doctor's requisition. Testing and in-office blood collection are available through Dr. MacLeod's practice at Optimal Wellbeing Clinic in Bedford.</p>
  </HeroSection>

  <section class="border-b border-slate-100 bg-white py-12">
    <div class="section-shell">
      <div class="mx-auto max-w-4xl text-center">
        <p class="text-lg leading-relaxed text-slate-700">
          Private testing can provide access to routine and specialized laboratory assessments when you do not have a family physician, when provincial testing is difficult to access or when a broader clinical picture would be useful. Tests are selected during a consultation based on your symptoms, medical history and goals.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white py-10 sm:py-16 lg:py-20" aria-label="Laboratory testing benefits">
    <div class="section-shell">
      <div class="grid grid-cols-2 gap-5 sm:gap-8 lg:grid-cols-4">
        {benefits.map(({ title, description, icon: Icon }) => (
          <div class="text-center">
            <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-emerald-100 sm:mb-4 sm:h-16 sm:w-16">
              <Icon class="h-6 w-6 text-emerald-700 sm:h-8 sm:w-8" stroke-width={1.5} aria-hidden="true" />
            </div>
            <h2 class="mb-2 text-base font-serif font-medium text-emerald-950 sm:text-lg">{title}</h2>
            <p class="text-xs leading-relaxed text-slate-600 sm:text-sm">{description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-emerald-50 py-16 lg:py-24">
    <div class="section-shell">
      <div class="mb-10 text-center sm:mb-12">
        <h2 class="mb-4 text-3xl font-serif font-medium text-emerald-950 sm:text-4xl">Available Testing</h2>
        <p class="mx-auto max-w-3xl text-lg text-slate-600">Testing is individualized; these are common categories available through the practice.</p>
      </div>

      <div class="space-y-1 sm:hidden">
        {testingOptions.map((option) => (
          <a href={option.href} class="group flex items-center gap-3 border-b border-emerald-100 py-4 font-medium text-slate-700 transition-colors hover:text-emerald-700">
            <ChevronRight class="h-4 w-4 flex-none text-emerald-500 transition-transform group-hover:translate-x-0.5" aria-hidden="true" />
            {option.title}
          </a>
        ))}
      </div>

      <div class="hidden gap-7 sm:grid sm:grid-cols-2 lg:grid-cols-3">
        {testingOptions.map((option) => (
          <a href={option.href} class="site-card-interactive group overflow-hidden">
            <div class="aspect-[16/10] overflow-hidden">
              <img
                src={option.image}
                alt={option.alt}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                width="800"
                height="500"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="p-6">
              <h3 class="mb-3 text-xl font-serif font-medium text-emerald-950 transition-colors group-hover:text-emerald-700">{option.title}</h3>
              <p class="mb-4 leading-relaxed text-slate-600">{option.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-emerald-700">
                Learn more <ChevronRight class="ml-1 h-4 w-4" aria-hidden="true" />
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <h2 class="mb-10 text-center text-3xl font-serif font-medium text-emerald-950 sm:text-4xl">How It Works</h2>
      <ol class="grid grid-cols-2 gap-5 sm:gap-8 lg:grid-cols-4">
        {steps.map(([number, title, description]) => (
          <li class="text-center">
            <span class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-emerald-700 text-xl font-semibold text-white sm:mb-4 sm:h-16 sm:w-16 sm:text-2xl">{number}</span>
            <h3 class="mb-2 text-base font-serif font-medium text-emerald-950 sm:text-lg">{title}</h3>
            <p class="text-xs leading-relaxed text-slate-600 sm:text-sm">{description}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="bg-emerald-950 py-16 lg:py-24">
    <div class="section-shell">
      <div class="grid items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-14">
        <div>
          <h2 class="mb-6 text-3xl font-serif font-medium text-white sm:text-4xl">Understanding Your Results</h2>
          <div class="space-y-5 text-lg leading-relaxed text-white/85">
            <p>Laboratory reference ranges help identify results outside the expected population range, but a number should not be interpreted in isolation.</p>
            <p>Dr. MacLeod reviews symptoms, medications, health history, trends over time and relationships between markers to understand what the complete pattern may mean for an individual patient.</p>
          </div>
        </div>
        <div class="rounded-2xl border border-white/15 bg-white/10 p-7 sm:p-8">
          <h3 class="mb-3 text-xl font-serif font-medium text-white">Testing should answer a clinical question</h3>
          <p class="leading-relaxed text-white/75">More testing is not automatically better. The goal is to choose assessments that are relevant to your situation and likely to influence care.</p>
        </div>
      </div>
    </div>
  </section>

  <FAQSection bg="white" items={faqs} />

  <section class="bg-emerald-950 py-16 lg:py-20">
    <div class="section-shell text-center">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-5 text-3xl font-serif font-medium text-white sm:text-4xl">Ready to Discuss Laboratory Testing?</h2>
        <p class="mb-8 text-lg leading-relaxed text-white/85">Book an initial consultation to review your concerns and determine which testing, if any, is appropriate for you.</p>
        <CTAButton source="lab-testing-cta" />
      </div>
    </div>
  </section>
</BaseLayout>
