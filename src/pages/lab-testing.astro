---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ClinicalContentLayout from '../components/ClinicalContentLayout.astro';
import ClinicalPageCTA from '../components/ClinicalPageCTA.astro';
import FAQSection from '../components/FAQSection.astro';
import RelatedCare from '../components/RelatedCare.astro';
import { ClipboardCheck, TestTubes, Clock, Sparkles, ChevronRight } from '@lucide/astro';

const tocItems = [
  { id: 'overview', title: 'Private Testing Overview' },
  { id: 'available-testing', title: 'Available Testing' },
  { id: 'how-it-works', title: 'How It Works' },
  { id: 'understanding-results', title: 'Understanding Results' },
  { id: 'frequently-asked-questions', title: 'Frequently Asked Questions' },
];

const testingOptions = [
  {
    title: 'Complete Thyroid Panel',
    description: 'Go beyond standard TSH testing with Free T3, Free T4, Reverse T3 and thyroid antibodies.',
    href: '/thyroid-testing/',
    image: '/images/lab-testing/thyroid-panel.webp',
    alt: 'Thyroid gland anatomy illustration',
  },
  {
    title: 'Hormone Testing',
    description: 'Assessment of sex hormones, cortisol and DHEA using blood, saliva or urine when appropriate.',
    href: '/hormone-testing/',
    image: '/images/lab-testing/hormone-testing.webp',
    alt: 'Hormone testing blood vials',
  },
  {
    title: 'Nutrient Status',
    description: 'Assess vitamin D, B12, iron, magnesium, zinc and other nutrients that may affect health.',
    href: '/nutrient-testing/',
    image: '/images/lab-testing/nutrient-status.webp',
    alt: 'Nutritious foods associated with nutrient status',
  },
  {
    title: 'Wellness Baseline',
    description: 'Comprehensive screening that may include blood counts, metabolic markers, lipids and blood sugar.',
    href: '/wellness-blood-work/',
    image: '/images/lab-testing/in-office-wellness-blood-work.webp',
    alt: 'Dr. Colin MacLeod preparing a patient for in-office blood work',
  },
  {
    title: 'Digestive Health',
    description: 'Stool analysis and other assessments selected according to symptoms and clinical history.',
    href: '/digestive-health-testing/',
    image: '/images/lab-testing/digestive-health.webp',
    alt: 'Digestive system illustration',
  },
  {
    title: 'Specialized Testing',
    description: 'Selected assessments for complex cases, including heavy metals, organic acids and other panels.',
    href: '/specialized-testing/',
    image: '/images/lab-testing/specialized-testing.webp',
    alt: 'Blood draw preparation for specialized testing',
  },
];

const faqs = [
  { question: "Do I need a doctor's referral for blood work?", answer: "<p>No. You can access comprehensive blood work without a family doctor's requisition. This can be helpful if you do not have a family doctor or want to discuss testing that is not routinely ordered.</p>" },
  { question: 'Is private blood work covered by MSI?', answer: '<p>Testing ordered through a naturopathic doctor is not covered by MSI. Many extended health insurance plans cover naturopathic consultations, while laboratory costs are generally paid out of pocket. Check your individual plan for details.</p>' },
  { question: 'Where is the blood draw performed?', answer: "<p>Dr. MacLeod performs blood collection in the clinic, so you generally will not need to visit a separate laboratory.</p>" },
  { question: 'How long until I get my results?', answer: '<p>Many standard blood tests return within 5–10 business days. Specialized tests such as comprehensive stool analysis or hormone panels may take 2–3 weeks. A follow-up is arranged once the relevant results are available.</p>' },
  { question: 'Do I need to fast before blood tests?', answer: '<p>Some tests require fasting and others do not. You will receive preparation instructions for the tests being ordered.</p>' },
];
---

<BaseLayout
  title="Private Blood Testing and Lab Testing in Halifax"
  description="Private blood work and lab testing in Halifax. Hormone panels, thyroid, nutrient assessments and more. No family doctor requisition required."
  focusKeyword="private blood work Halifax"
>
  <HeroSection
    title="Laboratory Testing"
    compact
    image={{
      src: '/images/lab-testing/in-office-blood-draw.webp',
      alt: 'Dr. Colin MacLeod performing an in-office blood draw',
      aspect: 'square',
    }}
  >
    <p>Get the blood work and laboratory testing you need without a family doctor's requisition. Testing and in-office blood collection are available through Dr. MacLeod's practice at Optimal Wellbeing Clinic in Bedford.</p>
  </HeroSection>

  <ClinicalContentLayout tocItems={tocItems} prose={false}>
    <div class="space-y-16 lg:space-y-20">
      <section id="overview">
        <h2 class="sr-only">Private Testing Overview</h2>
        <p class="mb-8 text-lg leading-relaxed text-slate-700">
          Private testing can provide access to routine and specialized laboratory assessments when you do not have a family physician, when provincial testing is difficult to access or when a broader clinical picture would be useful. Tests are selected during a consultation based on your symptoms, medical history and goals.
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="site-card p-5">
            <ClipboardCheck class="mb-3 h-7 w-7 text-emerald-700" stroke-width={1.5} aria-hidden="true" />
            <h3 class="mb-2 text-lg font-serif font-medium text-emerald-950">No Family-Doctor Requisition</h3>
            <p class="text-sm leading-relaxed text-slate-600">Dr. MacLeod can order appropriate testing for patients of the practice.</p>
          </div>
          <div class="site-card p-5">
            <TestTubes class="mb-3 h-7 w-7 text-emerald-700" stroke-width={1.5} aria-hidden="true" />
            <h3 class="mb-2 text-lg font-serif font-medium text-emerald-950">Broad Testing Options</h3>
            <p class="text-sm leading-relaxed text-slate-600">Options range from general wellness blood work to selected specialized panels.</p>
          </div>
          <div class="site-card p-5">
            <Clock class="mb-3 h-7 w-7 text-emerald-700" stroke-width={1.5} aria-hidden="true" />
            <h3 class="mb-2 text-lg font-serif font-medium text-emerald-950">In-Office Collection</h3>
            <p class="text-sm leading-relaxed text-slate-600">Blood collection is performed in the clinic for tests available through the practice.</p>
          </div>
          <div class="site-card p-5">
            <Sparkles class="mb-3 h-7 w-7 text-emerald-700" stroke-width={1.5} aria-hidden="true" />
            <h3 class="mb-2 text-lg font-serif font-medium text-emerald-950">Clinical Interpretation</h3>
            <p class="text-sm leading-relaxed text-slate-600">Results are reviewed in the context of your symptoms, history and other clinical information.</p>
          </div>
        </div>
      </section>

      <section id="available-testing">
        <div class="mb-7">
          <h2 class="mb-3 text-3xl font-serif font-medium text-emerald-950">Available Testing</h2>
          <p class="text-lg text-slate-600">Testing is individualized; these are common categories available through the practice.</p>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          {testingOptions.map((option) => (
            <a href={option.href} class="site-card-interactive group overflow-hidden">
              <div class="aspect-[16/9] overflow-hidden">
                <img
                  src={option.image}
                  alt={option.alt}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                  width="800"
                  height="450"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-5">
                <h3 class="mb-2 text-xl font-serif font-medium text-emerald-950 group-hover:text-emerald-700">{option.title}</h3>
                <p class="text-sm leading-relaxed text-slate-600">{option.description}</p>
                <span class="mt-4 inline-flex items-center text-sm font-semibold text-emerald-700">
                  Learn more <ChevronRight class="ml-1 h-4 w-4" aria-hidden="true" />
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section id="how-it-works">
        <h2 class="mb-7 text-3xl font-serif font-medium text-emerald-950">How It Works</h2>
        <ol class="grid gap-5 sm:grid-cols-2">
          {[
            ['1', 'Initial Consultation', 'Discuss your health concerns, history and goals with Dr. MacLeod.'],
            ['2', 'Select Testing', 'Dr. MacLeod determines which tests are appropriate and explains the expected costs.'],
            ['3', 'Sample Collection', 'Blood collection is performed in the clinic, with preparation instructions provided in advance.'],
            ['4', 'Review Results', 'Results are reviewed in context and used to guide practical recommendations or further assessment.'],
          ].map(([number, title, description]) => (
            <li class="site-card flex gap-4 p-5">
              <span class="flex h-10 w-10 flex-none items-center justify-center rounded-full bg-emerald-800 font-semibold text-white">{number}</span>
              <div>
                <h3 class="mb-1 text-lg font-serif font-medium text-emerald-950">{title}</h3>
                <p class="text-sm leading-relaxed text-slate-600">{description}</p>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <section id="understanding-results">
        <h2 class="mb-4 text-3xl font-serif font-medium text-emerald-950">Understanding Your Results</h2>
        <div class="space-y-5 text-lg leading-relaxed text-slate-700">
          <p>Laboratory reference ranges are useful for identifying values outside the expected population range, but a number should not be interpreted in isolation. Symptoms, medications, health history, trends over time and relationships between markers can all affect what a result means for an individual patient.</p>
          <p>Dr. MacLeod reviews the complete pattern rather than treating a single result as a diagnosis. When appropriate, recommendations may include follow-up testing, nutrition or lifestyle changes, supplementation or coordination with another healthcare provider.</p>
        </div>
        <div class="mt-7 rounded-2xl border border-emerald-100 bg-emerald-50 p-6">
          <h3 class="mb-2 text-xl font-serif font-medium text-emerald-950">Testing should answer a clinical question</h3>
          <p class="leading-relaxed text-slate-600">More testing is not automatically better. The goal is to choose assessments that are relevant to your situation and likely to influence care.</p>
        </div>
      </section>
    </div>
  </ClinicalContentLayout>

  <FAQSection id="frequently-asked-questions" bg="emerald" items={faqs} />

  <RelatedCare
    title="Related Testing"
    hubHref="/services/"
    hubLabel="Services"
    links={[
      { title: 'Thyroid Testing', href: '/thyroid-testing/', description: 'A broader assessment of thyroid function and antibodies.' },
      { title: 'Digestive Health Testing', href: '/digestive-health-testing/', description: 'Selected testing for persistent digestive symptoms.' },
      { title: 'Wellness Blood Work', href: '/wellness-blood-work/', description: 'Baseline blood work and preventive health assessment.' },
    ]}
  />

  <ClinicalPageCTA
    title="Ready to Discuss Laboratory Testing?"
    description="Book an initial consultation to review your concerns and determine which testing, if any, is appropriate for you."
    source="clinical-page-cta-lab-testing"
  />
</BaseLayout>
