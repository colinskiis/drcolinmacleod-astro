---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CTAButton from '../components/CTAButton.astro';
import FAQSection from '../components/FAQSection.astro';
import RelatedCare from '../components/RelatedCare.astro';
import { ArrowRight, Check, Info } from '@lucide/astro';

const coreGroups = [
  {
    abbreviation: 'CBC',
    name: 'Complete blood count',
    description: 'Measures red blood cells, white blood cells and platelets. The individual values and cell indices can contribute to the assessment of anemia, infection and some blood disorders.',
    markers: 'Hemoglobin, hematocrit, MCV, white blood cell count and platelets',
  },
  {
    abbreviation: 'A1C',
    name: 'Blood glucose markers',
    description: 'Fasting glucose measures blood sugar at the time of collection. HbA1c estimates average blood glucose over approximately the previous two to three months.',
    markers: 'Fasting glucose and HbA1c, selected according to the clinical question',
  },
  {
    abbreviation: 'Lipid',
    name: 'Lipid profile',
    description: 'Measures cholesterol carried in different lipoproteins and triglycerides. Results are considered with blood pressure, smoking, diabetes, family history and other cardiovascular risk factors.',
    markers: 'Total cholesterol, LDL-C, HDL-C and triglycerides',
  },
  {
    abbreviation: 'Renal',
    name: 'Kidney function and electrolytes',
    description: 'Creatinine and estimated glomerular filtration rate provide information about kidney filtration. Electrolytes help assess fluid and mineral balance.',
    markers: 'Creatinine, eGFR, sodium and potassium',
  },
  {
    abbreviation: 'Liver',
    name: 'Liver-associated markers',
    description: 'Enzymes and related markers can change with liver or biliary conditions, medication use and other health factors. An abnormal result does not identify the cause by itself.',
    markers: 'ALT, AST, ALP, GGT, bilirubin and albumin, when appropriate',
  },
  {
    abbreviation: 'Other',
    name: 'Additional tests when indicated',
    description: 'Thyroid, iron, vitamin B12, inflammatory and other markers may be added when symptoms, history, medications or previous results provide a reason to include them.',
    markers: 'Selected individually rather than included automatically',
  },
];

const reasonsToTest = [
  'No recent primary care or limited access to routine blood work',
  'A previous result that requires reassessment or monitoring',
  'Symptoms that warrant a broader clinical assessment',
  'Medication use that requires laboratory monitoring',
  'Personal or family risk factors for diabetes or cardiovascular disease',
  'Establishing selected baseline values before a health intervention',
];

const interpretationFactors = [
  {
    title: 'Reference intervals',
    text: "Results are compared with the reporting laboratory's intervals and decision thresholds. A value near a boundary is interpreted in context rather than labelled independently as healthy or unhealthy.",
  },
  {
    title: 'Trends over time',
    text: 'A previous result can help show whether a marker is stable, changing or returning toward baseline. Small differences can also reflect normal biological and laboratory variation.',
  },
  {
    title: 'Factors affecting results',
    text: 'Meals, hydration, exercise, acute illness, medications, supplements and the time of collection can affect particular measurements.',
  },
];
---

<BaseLayout
  title="Wellness Blood Work in Halifax | Health Screening"
  description="Private wellness blood work in Halifax, including CBC, glucose, lipids, kidney and liver markers when appropriate. Available without a family doctor requisition."
  focusKeyword="wellness blood work Halifax"
>
  <HeroSection
    title="Wellness Blood Work"
    compact
    image={{ src: '/images/lab-testing/in-office-wellness-blood-work.webp', alt: 'Dr. Colin MacLeod preparing a patient for in-office blood work', aspect: 'square' }}
  >
    <p>
      Wellness blood work provides selected baseline or follow-up information about blood cells, glucose regulation, lipids, kidney function and liver-associated markers. Testing can be arranged <strong class="text-white">without a family doctor requisition</strong> and is tailored to your history and reason for testing.
    </p>
  </HeroSection>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div>
            <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">A clinical, stepwise approach</p>
            <h2 class="mb-5 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">The panel is built around the purpose of testing</h2>
            <p class="text-lg leading-relaxed text-slate-600">
              There is no single wellness panel that is appropriate for everyone. Age, symptoms, medical and family history, medications, previous results and the time since the last assessment help determine which markers are useful.
            </p>
          </div>

          <ol class="divide-y divide-emerald-100 rounded-2xl border border-emerald-200 bg-emerald-50/60 px-6 sm:px-8">
            <li class="grid grid-cols-[2.5rem_1fr] gap-4 py-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-950 text-sm font-semibold text-white">1</span>
              <div>
                <h3 class="mb-1 font-semibold text-emerald-950">Review the context</h3>
                <p class="leading-relaxed text-slate-600">Current concerns, health history, medications and available previous results establish the purpose of testing.</p>
              </div>
            </li>
            <li class="grid grid-cols-[2.5rem_1fr] gap-4 py-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-950 text-sm font-semibold text-white">2</span>
              <div>
                <h3 class="mb-1 font-semibold text-emerald-950">Select the markers</h3>
                <p class="leading-relaxed text-slate-600">Core blood tests and any additional markers are chosen because they address a specific screening or monitoring question.</p>
              </div>
            </li>
            <li class="grid grid-cols-[2.5rem_1fr] gap-4 py-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-950 text-sm font-semibold text-white">3</span>
              <div>
                <h3 class="mb-1 font-semibold text-emerald-950">Review results and next steps</h3>
                <p class="leading-relaxed text-slate-600">Results are interpreted together. Follow-up may include monitoring, further assessment or coordination with primary or urgent medical care.</p>
              </div>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-emerald-50 py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-6xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Common components</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">What wellness blood work may include</h2>
          <p class="text-lg leading-relaxed text-slate-600">These groups describe commonly considered tests. The actual requisition may contain fewer markers or additional tests based on the clinical question.</p>
        </div>

        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {coreGroups.map((group) => (
            <article class="rounded-2xl border border-emerald-200 bg-white p-7 shadow-sm">
              <div class="mb-5 flex items-center gap-4">
                <span class="flex h-12 min-w-12 items-center justify-center rounded-xl bg-emerald-950 px-2 text-xs font-bold text-white">{group.abbreviation}</span>
                <h3 class="text-xl font-semibold leading-tight text-emerald-950">{group.name}</h3>
              </div>
              <p class="mb-5 leading-relaxed text-slate-600">{group.description}</p>
              <p class="border-t border-emerald-100 pt-4 text-sm leading-relaxed text-slate-500"><span class="font-semibold text-emerald-900">May include:</span> {group.markers}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Understanding the report</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">Results require context</h2>
          <p class="text-lg leading-relaxed text-slate-600">A blood test is one part of an assessment. It can provide useful evidence, but it does not replace symptoms, history, physical examination or appropriate diagnostic follow-up.</p>
        </div>

        <div class="grid gap-5 md:grid-cols-3">
          {interpretationFactors.map((factor) => (
            <article class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
              <h3 class="mb-3 text-lg font-semibold text-emerald-950">{factor.title}</h3>
              <p class="text-sm leading-relaxed text-slate-600">{factor.text}</p>
            </article>
          ))}
        </div>

        <div class="mt-6 flex gap-3 rounded-xl bg-amber-50 p-5 text-sm leading-relaxed text-amber-950 ring-1 ring-amber-200">
          <Info class="mt-0.5 h-5 w-5 flex-none" aria-hidden="true" />
          <p>Significantly abnormal or time-sensitive findings may require prompt assessment through primary care, a walk-in clinic or emergency care. Private laboratory testing does not replace those services.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-emerald-950 py-16 lg:py-20">
    <div class="section-shell">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
        <div>
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-300">Reasons for assessment</p>
          <h2 class="mb-5 text-3xl font-medium text-white sm:text-4xl font-serif">When wellness blood work may be useful</h2>
          <p class="leading-relaxed text-emerald-50/85">Testing frequency and scope are individualized. These circumstances can prompt a discussion, but none automatically requires a comprehensive panel.</p>
        </div>
        <ul class="grid gap-3 sm:grid-cols-2">
          {reasonsToTest.map((reason) => (
            <li class="flex gap-3 rounded-xl border border-white/15 bg-white/10 p-4 text-sm leading-relaxed text-white">
              <Check class="mt-0.5 h-5 w-5 flex-none text-emerald-300" aria-hidden="true" />
              <span>{reason}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Private testing in Nova Scotia</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">How the testing process works</h2>
          <p class="text-lg leading-relaxed text-slate-600">A family doctor or specialist referral is not required. The choice of tests and any preparation instructions are reviewed before collection.</p>
        </div>

        <ol class="grid gap-5 md:grid-cols-3">
          <li class="rounded-2xl border border-emerald-200 p-6">
            <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 font-semibold text-emerald-800">1</span>
            <h3 class="mb-2 text-lg font-semibold text-emerald-950">Clinical review</h3>
            <p class="text-sm leading-relaxed text-slate-600">Your reason for testing, health history, medications and previous results are reviewed.</p>
          </li>
          <li class="rounded-2xl border border-emerald-200 p-6">
            <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 font-semibold text-emerald-800">2</span>
            <h3 class="mb-2 text-lg font-semibold text-emerald-950">Requisition and collection</h3>
            <p class="text-sm leading-relaxed text-slate-600">A private laboratory requisition is provided. Costs and any fasting or timing instructions are confirmed in advance.</p>
          </li>
          <li class="rounded-2xl border border-emerald-200 p-6">
            <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 font-semibold text-emerald-800">3</span>
            <h3 class="mb-2 text-lg font-semibold text-emerald-950">Results and follow-up</h3>
            <p class="text-sm leading-relaxed text-slate-600">Results are reviewed as a group, with follow-up based on the findings and the reason the tests were ordered.</p>
          </li>
        </ol>

        <div class="mt-8 flex items-start gap-4 rounded-2xl bg-emerald-50 p-6 sm:items-center sm:justify-between">
          <p class="max-w-2xl text-sm leading-relaxed text-slate-600">Laboratory testing ordered through a naturopathic doctor is not covered by MSI. Some extended health plans may cover naturopathic appointments, but laboratory coverage varies.</p>
          <ArrowRight class="hidden h-6 w-6 flex-none text-emerald-700 sm:block" aria-hidden="true" />
        </div>
      </div>
    </div>
  </section>

  <RelatedCare
    title="Related Testing"
    hubHref="/lab-testing/"
    hubLabel="Lab Testing"
    links={[
      { title: 'Nutrient Status', href: '/nutrient-testing/' },
      { title: 'Complete Thyroid Panel', href: '/thyroid-testing/' },
      { title: 'Hormone Testing', href: '/hormone-testing/' },
    ]}
  />

  <FAQSection bg="white" items={[
    {
      question: 'Can I get blood work without a family doctor?',
      answer: '<p>Yes. After a clinical review, I can provide a private laboratory requisition for the tests that are appropriate. A family doctor or specialist referral is not required.</p>',
    },
    {
      question: 'Is wellness blood work covered by MSI?',
      answer: '<p>Laboratory testing ordered through a naturopathic doctor is not covered by MSI and is paid privately. The cost depends on the markers selected and is reviewed before testing.</p>',
    },
    {
      question: 'Do I need a comprehensive panel?',
      answer: '<p>Not necessarily. Testing should address a defined screening or monitoring question. Previous results, age, symptoms, history, medications and risk factors help determine whether a smaller set of tests or a broader panel is appropriate.</p>',
    },
    {
      question: 'Do I need to fast before blood work?',
      answer: '<p>It depends on the tests selected. Some measurements are affected by recent food intake while others do not require fasting. You will receive specific instructions before collection. Unless instructed otherwise, water is permitted and medications should not be stopped.</p>',
    },
    {
      question: 'How often should wellness blood work be repeated?',
      answer: '<p>There is no single interval for everyone. Timing depends on age, risk factors, medications, previous findings and whether a result is being monitored after an intervention. Unnecessary repeat testing is avoided.</p>',
    },
    {
      question: 'Can the results be shared with my family doctor?',
      answer: '<p>Yes. You can receive a copy for your records or provide it to another healthcare professional. Findings that require medical diagnosis or treatment should be followed through the appropriate primary or specialist care pathway.</p>',
    },
  ]} />

  <section class="bg-emerald-950 py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="mb-6 text-3xl font-medium text-white sm:text-4xl font-serif">Discuss Whether Wellness Blood Work Is Appropriate</h2>
        <p class="mb-8 text-lg leading-relaxed text-white/90">Book an initial consultation to review your health history, previous results and which baseline or follow-up markers would provide useful information.</p>
        <CTAButton source="wellness-blood-work-cta" />
      </div>
    </div>
  </section>
</BaseLayout>
