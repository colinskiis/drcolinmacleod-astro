---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CTAButton from '../components/CTAButton.astro';
import FAQSection from '../components/FAQSection.astro';
import RelatedCare from '../components/RelatedCare.astro';
import { ArrowRight, Check, Info, TriangleAlert } from '@lucide/astro';

const testQuestions = [
  {
    question: 'Could this be celiac disease?',
    test: 'Celiac serology',
    details: 'Tissue transglutaminase IgA (tTG-IgA) with total IgA is commonly used for initial testing. Additional markers may be appropriate in selected circumstances.',
    limitation: 'Testing should be done while eating gluten. A positive result may require medical referral and small-bowel biopsy for confirmation.',
  },
  {
    question: 'Is intestinal inflammation present?',
    test: 'Fecal calprotectin and blood markers',
    details: 'Fecal calprotectin, CBC and C-reactive protein can contribute to distinguishing an inflammatory process from a functional bowel disorder.',
    limitation: 'An abnormal result does not identify the cause. Further medical assessment, imaging or endoscopy may be needed.',
  },
  {
    question: 'Is an intestinal infection plausible?',
    test: 'Targeted stool pathogen testing',
    details: 'Testing may look for specific bacteria, parasites or viruses when the history includes acute or persistent diarrhea, travel, exposure or immune risk.',
    limitation: 'The panel should match the clinical history. Broad testing in the absence of a relevant exposure or symptom pattern can produce findings of uncertain significance.',
  },
  {
    question: 'Could pancreatic enzyme production be low?',
    test: 'Fecal elastase',
    details: 'Fecal elastase is an initial test for suspected exocrine pancreatic insufficiency, particularly with greasy stool, weight loss, malabsorption or pancreatic risk factors.',
    limitation: 'The sample must be formed or semi-formed. Values below 100 µg/g support insufficiency; results from 100–200 µg/g are indeterminate.',
  },
  {
    question: 'Is SIBO reasonably suspected?',
    test: 'Hydrogen and methane breath testing',
    details: 'Breath samples are collected after a glucose or lactulose substrate to measure gases produced by intestinal microorganisms.',
    limitation: 'Preparation, substrate and intestinal transit affect results. False-positive and false-negative results occur, so testing is not appropriate for every person with bloating.',
  },
  {
    question: 'Would a specialty stool panel add useful information?',
    test: 'Selected qPCR stool analysis',
    details: 'Some private panels use molecular methods to detect microbial DNA and may also report digestive or inflammatory markers.',
    limitation: 'Detecting DNA does not prove that an organism is alive, causing symptoms or requires treatment. Microbiome and “dysbiosis” findings do not have universally accepted clinical thresholds.',
  },
];

const warningSigns = [
  'Visible blood in the stool or black, tarry stool',
  'Unintentional weight loss or evidence of malnutrition',
  'Persistent vomiting, fever, dehydration or severe or worsening abdominal pain',
  'Iron-deficiency anemia or other significant laboratory abnormalities',
  'New bowel symptoms later in life',
  'A strong family history of colorectal cancer, inflammatory bowel disease or celiac disease',
];

const reasonsToConsider = [
  'Persistent diarrhea, constipation or alternating bowel habits after an initial assessment',
  'Ongoing bloating or abdominal discomfort where the result would change management',
  'Symptoms or risk factors suggesting celiac disease or malabsorption',
  'Greasy stool, unexplained weight loss or another concern about pancreatic function',
  'Persistent diarrhea following travel, infection or a relevant exposure',
  'A previous digestive test that was abnormal or requires follow-up',
];
---

<BaseLayout
  title="Digestive Health Testing in Halifax | Celiac, SIBO & Stool Tests"
  description="Private digestive health testing in Halifax, including celiac blood work, fecal calprotectin, targeted stool testing, SIBO breath testing and fecal elastase when appropriate."
  focusKeyword="digestive health testing Halifax"
>
  <HeroSection
    title="Digestive Health Testing"
    compact
    image={{ src: '/images/lab-testing/digestive-health.webp', alt: 'Illustration of the human digestive system', aspect: 'video' }}
  >
    <p>
      Digestive testing can help investigate persistent bowel changes, abdominal symptoms, possible malabsorption or an abnormal previous result. Testing is selected according to the clinical question and interpreted with symptoms, history and relevant warning signs.
    </p>
  </HeroSection>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div>
            <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Assessment before testing</p>
            <h2 class="mb-5 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">Symptoms determine the next question</h2>
            <p class="text-lg leading-relaxed text-slate-600">
              There is no single test that explains every case of bloating, pain, diarrhea or constipation. The pattern and duration of symptoms, diet, medications, travel, previous investigations and family history help determine whether testing is needed and which test is appropriate.
            </p>
          </div>

          <ol class="divide-y divide-emerald-100 rounded-2xl border border-emerald-200 bg-emerald-50/60 px-6 sm:px-8">
            <li class="grid grid-cols-[2.5rem_1fr] gap-4 py-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-950 text-sm font-semibold text-white">1</span>
              <div>
                <h3 class="mb-1 font-semibold text-emerald-950">Describe the symptom pattern</h3>
                <p class="leading-relaxed text-slate-600">Timing, stool pattern, associated symptoms and relevant exposures narrow the possibilities.</p>
              </div>
            </li>
            <li class="grid grid-cols-[2.5rem_1fr] gap-4 py-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-950 text-sm font-semibold text-white">2</span>
              <div>
                <h3 class="mb-1 font-semibold text-emerald-950">Check for warning signs</h3>
                <p class="leading-relaxed text-slate-600">Some findings require primary, urgent or specialist medical assessment rather than private testing alone.</p>
              </div>
            </li>
            <li class="grid grid-cols-[2.5rem_1fr] gap-4 py-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-950 text-sm font-semibold text-white">3</span>
              <div>
                <h3 class="mb-1 font-semibold text-emerald-950">Order only useful tests</h3>
                <p class="leading-relaxed text-slate-600">A test is selected when its result is likely to clarify the assessment or change the next step.</p>
              </div>
            </li>
          </ol>
        </div>

        <aside class="mt-10 rounded-2xl border border-amber-200 bg-amber-50 p-7 sm:p-8" aria-labelledby="warning-signs-heading">
          <div class="grid gap-6 lg:grid-cols-[0.75fr_1.25fr]">
            <div class="flex gap-4">
              <TriangleAlert class="mt-1 h-6 w-6 flex-none text-amber-700" aria-hidden="true" />
              <div>
                <h3 id="warning-signs-heading" class="mb-2 text-xl font-semibold text-amber-950">Warning signs need medical assessment</h3>
                <p class="text-sm leading-relaxed text-amber-900/80">These findings may require prompt primary care, urgent care, emergency assessment or gastroenterology referral.</p>
              </div>
            </div>
            <ul class="grid gap-x-6 gap-y-3 sm:grid-cols-2">
              {warningSigns.map((sign) => (
                <li class="flex gap-2 text-sm leading-relaxed text-amber-950">
                  <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-amber-600" aria-hidden="true"></span>
                  <span>{sign}</span>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="bg-emerald-50 py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-6xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Tests selected by purpose</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">What digestive tests can—and cannot—answer</h2>
          <p class="text-lg leading-relaxed text-slate-600">The same symptom can arise from different conditions. Each test below has a specific role and an important limitation.</p>
        </div>

        <div class="overflow-hidden rounded-2xl border border-emerald-200 bg-white">
          <div class="hidden grid-cols-[1fr_0.8fr_1.25fr_1.25fr] gap-6 bg-emerald-950 px-7 py-4 text-xs font-semibold uppercase tracking-[0.12em] text-white lg:grid">
            <span>Clinical question</span>
            <span>Possible test</span>
            <span>What it measures</span>
            <span>Important limitation</span>
          </div>
          {testQuestions.map((item, index) => (
            <article class:list={['grid gap-4 p-6 lg:grid-cols-[1fr_0.8fr_1.25fr_1.25fr] lg:gap-6 lg:p-7', index !== testQuestions.length - 1 && 'border-b border-emerald-100']}>
              <div>
                <p class="mb-1 text-xs font-semibold uppercase tracking-[0.12em] text-emerald-700 lg:hidden">Clinical question</p>
                <h3 class="font-semibold leading-relaxed text-emerald-950">{item.question}</h3>
              </div>
              <div>
                <p class="mb-1 text-xs font-semibold uppercase tracking-[0.12em] text-emerald-700 lg:hidden">Possible test</p>
                <p class="font-medium leading-relaxed text-emerald-800">{item.test}</p>
              </div>
              <div>
                <p class="mb-1 text-xs font-semibold uppercase tracking-[0.12em] text-emerald-700 lg:hidden">What it measures</p>
                <p class="text-sm leading-relaxed text-slate-600">{item.details}</p>
              </div>
              <div>
                <p class="mb-1 text-xs font-semibold uppercase tracking-[0.12em] text-emerald-700 lg:hidden">Important limitation</p>
                <p class="text-sm leading-relaxed text-slate-600">{item.limitation}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Interpreting private testing</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">More detected organisms do not necessarily mean more answers</h2>
          <p class="text-lg leading-relaxed text-slate-600">Molecular stool panels can detect small amounts of microbial DNA. That analytical sensitivity must be distinguished from clinical significance.</p>
        </div>

        <div class="grid gap-5 md:grid-cols-3">
          <article class="rounded-2xl border border-slate-200 bg-slate-50 p-7">
            <h3 class="mb-3 text-lg font-semibold text-emerald-950">Detection is not causation</h3>
            <p class="text-sm leading-relaxed text-slate-600">A detected organism may represent colonization, transient passage or residual DNA rather than an active infection responsible for symptoms.</p>
          </article>
          <article class="rounded-2xl border border-slate-200 bg-slate-50 p-7">
            <h3 class="mb-3 text-lg font-semibold text-emerald-950">Context changes meaning</h3>
            <p class="text-sm leading-relaxed text-slate-600">The quantity detected, symptoms, immune status, exposures and findings from established tests all affect interpretation.</p>
          </article>
          <article class="rounded-2xl border border-slate-200 bg-slate-50 p-7">
            <h3 class="mb-3 text-lg font-semibold text-emerald-950">Treatment is not automatic</h3>
            <p class="text-sm leading-relaxed text-slate-600">An isolated molecular or microbiome result should not automatically lead to antimicrobial treatment or a restrictive diet.</p>
          </article>
        </div>

        <div class="mt-6 flex gap-3 rounded-xl bg-emerald-50 p-5 text-sm leading-relaxed text-slate-700 ring-1 ring-emerald-200">
          <Info class="mt-0.5 h-5 w-5 flex-none text-emerald-700" aria-hidden="true" />
          <p>Food-specific IgG panels and serum or stool zonulin testing are not offered here as diagnostic tests for food reactions or “leaky gut.” Food-related symptoms require a history-based assessment and, when appropriate, celiac testing, allergy evaluation, targeted breath testing or a structured elimination and reintroduction process.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-emerald-950 py-16 lg:py-20">
    <div class="section-shell">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
        <div>
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-300">Selecting tests</p>
          <h2 class="mb-5 text-3xl font-medium text-white sm:text-4xl font-serif">When digestive testing may be considered</h2>
          <p class="leading-relaxed text-emerald-50/85">These circumstances may justify focused testing after clinical review. They do not automatically require a broad stool panel.</p>
        </div>
        <ul class="grid gap-3 sm:grid-cols-2">
          {reasonsToConsider.map((reason) => (
            <li class="flex gap-3 rounded-xl border border-white/15 bg-white/10 p-4 text-sm leading-relaxed text-white">
              <Check class="mt-0.5 h-5 w-5 flex-none text-emerald-300" aria-hidden="true" />
              <span>{reason}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Private testing in Nova Scotia</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">How the testing process works</h2>
          <p class="text-lg leading-relaxed text-slate-600">A family doctor or gastroenterology referral is not required for private testing. Medical referral is recommended when the history, examination or results indicate that it is needed.</p>
        </div>

        <ol class="grid gap-5 md:grid-cols-3">
          <li class="rounded-2xl border border-emerald-200 p-6">
            <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 font-semibold text-emerald-800">1</span>
            <h3 class="mb-2 text-lg font-semibold text-emerald-950">Clinical review</h3>
            <p class="text-sm leading-relaxed text-slate-600">Symptoms, warning signs, diet, medications, exposures, family history and previous investigations are reviewed.</p>
          </li>
          <li class="rounded-2xl border border-emerald-200 p-6">
            <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 font-semibold text-emerald-800">2</span>
            <h3 class="mb-2 text-lg font-semibold text-emerald-950">Requisition or collection kit</h3>
            <p class="text-sm leading-relaxed text-slate-600">The smallest useful set of tests is selected. Costs and all diet, medication or collection instructions are confirmed first.</p>
          </li>
          <li class="rounded-2xl border border-emerald-200 p-6">
            <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 font-semibold text-emerald-800">3</span>
            <h3 class="mb-2 text-lg font-semibold text-emerald-950">Results and follow-up</h3>
            <p class="text-sm leading-relaxed text-slate-600">Results are reviewed with their limitations, including whether confirmation or medical investigation is required.</p>
          </li>
        </ol>

        <div class="mt-8 flex items-start gap-4 rounded-2xl bg-emerald-50 p-6 sm:items-center sm:justify-between">
          <p class="max-w-2xl text-sm leading-relaxed text-slate-600">Laboratory testing ordered through a naturopathic doctor is not covered by MSI. Some extended health plans may cover naturopathic appointments, but laboratory coverage varies.</p>
          <ArrowRight class="hidden h-6 w-6 flex-none text-emerald-700 sm:block" aria-hidden="true" />
        </div>
      </div>
    </div>
  </section>

  <RelatedCare
    title="Related Testing"
    hubHref="/lab-testing/"
    hubLabel="Lab Testing"
    links={[
      { title: 'Nutrient Status', href: '/nutrient-testing/' },
      { title: 'Wellness Blood Work', href: '/wellness-blood-work/' },
      { title: 'Specialized Testing', href: '/specialized-testing/' },
    ]}
  />

  <FAQSection bg="white" items={[
    {
      question: 'Do I need a comprehensive stool panel?',
      answer: '<p>Not necessarily. Testing should be selected according to the symptom pattern and the question being investigated. Celiac blood work, fecal calprotectin, a targeted pathogen test, a breath test or fecal elastase may be more appropriate than a broad panel.</p>',
    },
    {
      question: 'What is SIBO and how is it tested?',
      answer: '<p>Small intestinal bacterial overgrowth refers to an excessive number of microorganisms in the small intestine in a compatible clinical setting. Glucose or lactulose breath testing measures hydrogen and methane after a test substrate. Preparation and interpretation matter, and the test is not definitive in every case.</p>',
    },
    {
      question: 'Should I stop eating gluten before celiac testing?',
      answer: '<p>No. Celiac antibody testing and diagnostic biopsy are most accurate while gluten is still being eaten. Starting a gluten-free diet beforehand can produce a false-negative result. If you have already stopped gluten, discuss the situation before restarting it on your own.</p>',
    },
    {
      question: 'Can a stool panel diagnose dysbiosis?',
      answer: '<p>There is no single, universally accepted laboratory definition of dysbiosis. A specialty panel may report organisms and selected digestive or inflammatory markers, but the findings must be interpreted cautiously and do not automatically establish the cause of symptoms.</p>',
    },
    {
      question: 'Do you offer food sensitivity IgG testing?',
      answer: '<p>No. Food-specific IgG generally indicates exposure to a food rather than a clinically meaningful intolerance. Food-related symptoms are assessed through the history and, when appropriate, celiac testing, allergy evaluation, targeted breath testing or a structured elimination and reintroduction process.</p>',
    },
    {
      question: 'Do I need a referral for digestive testing?',
      answer: '<p>No family doctor or gastroenterology referral is required for private testing. However, warning signs or certain abnormal results may require referral for imaging, endoscopy, biopsy or other medical assessment that cannot be replaced by private laboratory testing.</p>',
    },
  ]} />

  <section class="bg-emerald-950 py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="mb-6 text-3xl font-medium text-white sm:text-4xl font-serif">Discuss Whether Digestive Testing Is Appropriate</h2>
        <p class="mb-8 text-lg leading-relaxed text-white/90">Book an initial consultation to review your symptoms, previous investigations and which digestive tests, if any, would provide useful information.</p>
        <CTAButton source="digestive-health-testing-cta" />
      </div>
    </div>
  </section>
</BaseLayout>
