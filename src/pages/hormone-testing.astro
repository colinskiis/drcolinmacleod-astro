---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CTAButton from '../components/CTAButton.astro';
import FAQSection from '../components/FAQSection.astro';
import RelatedCare from '../components/RelatedCare.astro';
import { ArrowRight, Check, Info } from '@lucide/astro';

const hormoneMarkers = [
  {
    abbreviation: 'E2',
    name: 'Estradiol',
    description: 'Estradiol is the principal circulating estrogen during the reproductive years. Its concentration varies across the menstrual cycle and changes substantially during the transition to menopause.',
  },
  {
    abbreviation: 'P4',
    name: 'Progesterone',
    description: 'Progesterone rises after ovulation. A correctly timed serum measurement can provide evidence that ovulation recently occurred, but a single value cannot assess the overall quality of the luteal phase.',
  },
  {
    abbreviation: 'T',
    name: 'Testosterone and SHBG',
    description: 'Total testosterone is usually the initial measurement. Sex hormone-binding globulin and calculated or measured free testosterone may add information when binding-protein changes affect interpretation.',
  },
  {
    abbreviation: 'FSH/LH',
    name: 'Gonadotropins',
    description: 'Follicle-stimulating hormone and luteinizing hormone are produced by the pituitary gland. They are interpreted with sex hormones, menstrual status and the reason for testing.',
  },
  {
    abbreviation: 'PRL',
    name: 'Prolactin',
    description: 'Prolactin can be relevant to absent or irregular periods, infertility, unexpected breast milk production and some testosterone concerns. Stress, exercise and medications can affect the result.',
  },
  {
    abbreviation: 'DHEA-S',
    name: 'DHEA sulfate',
    description: 'DHEA-S is an androgen produced mainly by the adrenal glands. It may be included when assessing androgen excess or particular adrenal questions, but it is not a general measure of vitality or biological ageing.',
  },
];

const testingMethods = [
  {
    method: 'Blood',
    role: 'The usual starting point',
    description: 'Serum testing is the established method for most reproductive and androgen assessments, including estradiol, progesterone, testosterone, SHBG, FSH, LH, prolactin and DHEA-S.',
  },
  {
    method: 'Saliva',
    role: 'A limited, question-specific role',
    description: 'Salivary cortisol has validated uses in particular endocrine evaluations, such as late-night testing for suspected cortisol excess. A multi-point profile does not diagnose “adrenal fatigue” or measure a person’s ability to cope with stress.',
  },
];

const timingFactors = [
  {
    title: 'Menstrual-cycle timing',
    text: 'Estradiol, LH, FSH and progesterone change across the cycle. If progesterone is being used to assess recent ovulation, collection is generally timed about one week before the expected next period rather than assigned to cycle day 21 for everyone.',
  },
  {
    title: 'Time of day and confirmation',
    text: 'Testosterone in men is generally measured in the morning. A low result should be confirmed on a separate morning sample and interpreted together with compatible symptoms and signs.',
  },
  {
    title: 'Medication and health status',
    text: 'Hormonal contraception, menopausal hormone therapy, testosterone, corticosteroids and several other medications can alter results. Acute illness, pregnancy and postpartum status also change interpretation.',
  },
];

const reasonsToConsider = [
  'Absent, infrequent or irregular menstrual periods that require assessment',
  'Possible ovulatory dysfunction or a fertility evaluation',
  'Clinical signs of androgen excess, such as new hirsutism or persistent acne',
  'Symptoms and signs compatible with testosterone deficiency in men',
  'A previous hormone result that was abnormal or requires confirmation',
  'Monitoring prescribed hormone treatment when laboratory follow-up is indicated',
];
---

<BaseLayout
  title="Hormone Testing in Halifax | Reproductive Hormone Assessment"
  description="Private hormone testing in Halifax, including estradiol, progesterone, testosterone, FSH, LH, prolactin and DHEA-S when clinically appropriate."
  focusKeyword="hormone testing Halifax"
>
  <HeroSection
    title="Hormone Testing"
    compact
    image={{ src: '/images/lab-testing/hormone-testing.webp', alt: 'Blood samples prepared for laboratory hormone testing', aspect: 'video' }}
  >
    <p>
      Hormone testing can help investigate menstrual changes, ovulation, androgen concerns and suspected hormone deficiency. The tests and their timing are selected for the clinical question and can be arranged <strong class="text-white">without a family doctor requisition</strong>.
    </p>
  </HeroSection>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div>
            <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">A clinical, stepwise approach</p>
            <h2 class="mb-5 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">Testing begins with a defined endocrine question</h2>
            <p class="text-lg leading-relaxed text-slate-600">
              Fatigue, mood changes, weight changes and low libido have many possible causes. Hormone tests are most informative when the history and clinical findings indicate which hormone system should be assessed.
            </p>
          </div>

          <ol class="divide-y divide-emerald-100 rounded-2xl border border-emerald-200 bg-emerald-50/60 px-6 sm:px-8">
            <li class="grid grid-cols-[2.5rem_1fr] gap-4 py-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-950 text-sm font-semibold text-white">1</span>
              <div>
                <h3 class="mb-1 font-semibold text-emerald-950">Clarify the concern</h3>
                <p class="leading-relaxed text-slate-600">Symptoms, menstrual or reproductive history, medications and previous results help identify the question being investigated.</p>
              </div>
            </li>
            <li class="grid grid-cols-[2.5rem_1fr] gap-4 py-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-950 text-sm font-semibold text-white">2</span>
              <div>
                <h3 class="mb-1 font-semibold text-emerald-950">Select and time the tests</h3>
                <p class="leading-relaxed text-slate-600">The markers, specimen and collection time are chosen according to physiology and the intended use of the result.</p>
              </div>
            </li>
            <li class="grid grid-cols-[2.5rem_1fr] gap-4 py-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-950 text-sm font-semibold text-white">3</span>
              <div>
                <h3 class="mb-1 font-semibold text-emerald-950">Interpret the pattern</h3>
                <p class="leading-relaxed text-slate-600">Results are interpreted together and may require confirmation or additional assessment before a diagnosis can be made.</p>
              </div>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-emerald-50 py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-6xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Common blood markers</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">What reproductive hormone tests measure</h2>
          <p class="text-lg leading-relaxed text-slate-600">Each marker answers a different question. A comprehensive assessment does not necessarily mean ordering every hormone listed here.</p>
        </div>

        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {hormoneMarkers.map((marker) => (
            <article class="rounded-2xl border border-emerald-200 bg-white p-7 shadow-sm">
              <div class="mb-6 flex items-center gap-4">
                <span class="flex h-12 min-w-12 items-center justify-center rounded-xl bg-emerald-950 px-2 text-xs font-bold text-white">{marker.abbreviation}</span>
                <h3 class="text-xl font-semibold leading-tight text-emerald-950">{marker.name}</h3>
              </div>
              <p class="leading-relaxed text-slate-600">{marker.description}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Choosing a specimen</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">Blood and saliva answer different questions</h2>
          <p class="text-lg leading-relaxed text-slate-600">The collection method is selected according to the established or intended use of the result. Convenience or the number of values on a report does not make one method inherently better.</p>
        </div>

        <div class="overflow-hidden rounded-2xl border border-emerald-200">
          {testingMethods.map((item, index) => (
            <div class:list={['grid gap-4 p-6 sm:grid-cols-[8rem_11rem_1fr] sm:gap-8 sm:p-7', index !== testingMethods.length - 1 && 'border-b border-emerald-100']}>
              <p class="text-xl font-semibold text-emerald-950">{item.method}</p>
              <p class="font-medium text-emerald-800">{item.role}</p>
              <p class="leading-relaxed text-slate-600">{item.description}</p>
            </div>
          ))}
        </div>

        <div class="mt-6 flex gap-3 rounded-xl bg-amber-50 p-5 text-sm leading-relaxed text-amber-950 ring-1 ring-amber-200">
          <Info class="mt-0.5 h-5 w-5 flex-none" aria-hidden="true" />
          <p>Salivary cortisol testing should not be used to diagnose “adrenal fatigue,” burnout or a person's ability to cope with stress. Suspected adrenal insufficiency or cortisol excess requires established endocrine testing.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Collection and interpretation</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">Timing can materially change the result</h2>
          <p class="text-lg leading-relaxed text-slate-600">Hormones vary with normal physiology. The date, time and circumstances of collection need to match the reason the test was ordered.</p>
        </div>

        <div class="grid gap-5 md:grid-cols-3">
          {timingFactors.map((factor) => (
            <article class="rounded-2xl border border-slate-200 bg-white p-7">
              <h3 class="mb-3 text-lg font-semibold text-emerald-950">{factor.title}</h3>
              <p class="text-sm leading-relaxed text-slate-600">{factor.text}</p>
            </article>
          ))}
        </div>

        <div class="mt-6 rounded-xl border border-emerald-200 bg-emerald-50 p-5 text-sm leading-relaxed text-slate-700">
          In otherwise healthy people aged 45 or older with typical perimenopause or menopause symptoms, the diagnosis is often based on clinical history rather than estradiol or FSH testing because hormone concentrations fluctuate and may not change management.
        </div>
      </div>
    </div>
  </section>

  <section class="bg-emerald-950 py-16 lg:py-20">
    <div class="section-shell">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
        <div>
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-300">Selecting tests</p>
          <h2 class="mb-5 text-3xl font-medium text-white sm:text-4xl font-serif">When hormone testing may be considered</h2>
          <p class="leading-relaxed text-emerald-50/85">These circumstances can justify a focused assessment. They do not automatically require every hormone marker or a specialized urine panel.</p>
        </div>
        <ul class="grid gap-3 sm:grid-cols-2">
          {reasonsToConsider.map((reason) => (
            <li class="flex gap-3 rounded-xl border border-white/15 bg-white/10 p-4 text-sm leading-relaxed text-white">
              <Check class="mt-0.5 h-5 w-5 flex-none text-emerald-300" aria-hidden="true" />
              <span>{reason}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Private testing in Nova Scotia</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">How the testing process works</h2>
          <p class="text-lg leading-relaxed text-slate-600">A family doctor or specialist referral is not required. Testing is selected and reviewed through the naturopathic appointment process.</p>
        </div>

        <ol class="grid gap-5 md:grid-cols-3">
          <li class="rounded-2xl border border-emerald-200 p-6">
            <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 font-semibold text-emerald-800">1</span>
            <h3 class="mb-2 text-lg font-semibold text-emerald-950">Clinical review</h3>
            <p class="text-sm leading-relaxed text-slate-600">Symptoms, reproductive history, medications, treatment and previous results are reviewed.</p>
          </li>
          <li class="rounded-2xl border border-emerald-200 p-6">
            <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 font-semibold text-emerald-800">2</span>
            <h3 class="mb-2 text-lg font-semibold text-emerald-950">Requisition and collection</h3>
            <p class="text-sm leading-relaxed text-slate-600">A private requisition or collection kit is provided. Costs and timing instructions are confirmed in advance.</p>
          </li>
          <li class="rounded-2xl border border-emerald-200 p-6">
            <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 font-semibold text-emerald-800">3</span>
            <h3 class="mb-2 text-lg font-semibold text-emerald-950">Results and follow-up</h3>
            <p class="text-sm leading-relaxed text-slate-600">Results are reviewed with their limitations. Abnormal findings may require confirmation or referral for medical evaluation.</p>
          </li>
        </ol>

        <div class="mt-8 flex items-start gap-4 rounded-2xl bg-emerald-50 p-6 sm:items-center sm:justify-between">
          <p class="max-w-2xl text-sm leading-relaxed text-slate-600">Laboratory testing ordered through a naturopathic doctor is not covered by MSI. Some extended health plans may cover naturopathic appointments, but laboratory coverage varies.</p>
          <ArrowRight class="hidden h-6 w-6 flex-none text-emerald-700 sm:block" aria-hidden="true" />
        </div>
      </div>
    </div>
  </section>

  <RelatedCare
    title="Related Testing"
    hubHref="/lab-testing/"
    hubLabel="Lab Testing"
    links={[
      { title: 'Complete Thyroid Panel', href: '/thyroid-testing/' },
      { title: 'Nutrient Status', href: '/nutrient-testing/' },
      { title: 'Specialized Testing', href: '/specialized-testing/' },
    ]}
  />

  <FAQSection bg="white" items={[
    {
      question: 'When should hormone testing be done in my menstrual cycle?',
      answer: '<p>It depends on the question and the marker. If progesterone is being used to assess whether ovulation recently occurred, collection is generally timed about one week before the expected next period, not automatically on days 19–21. FSH, LH and estradiol may require different timing. Instructions are provided before collection.</p>',
    },
    {
      question: 'Do I need a comprehensive hormone panel?',
      answer: '<p>Usually not. The tests should be selected to answer a defined clinical question. A focused blood panel, collected at the appropriate time and interpreted with the clinical history, is generally more useful than ordering every available hormone marker.</p>',
    },
    {
      question: 'Can hormone testing diagnose adrenal fatigue?',
      answer: '<p>No. Adrenal fatigue is not a recognized medical diagnosis, and multi-point salivary cortisol profiles have not been validated to diagnose it. Suspected adrenal insufficiency or cortisol excess requires an appropriate medical assessment and established endocrine testing.</p>',
    },
    {
      question: 'How is low testosterone assessed in men?',
      answer: '<p>A diagnosis requires compatible symptoms or signs together with consistently low testosterone concentrations. Testing generally begins with a morning total testosterone measurement, and a low result is confirmed on a separate morning sample. Additional markers may be needed to investigate the cause.</p>',
    },
    {
      question: 'Do menopause symptoms require hormone testing?',
      answer: '<p>Often they do not. In otherwise healthy people aged 45 or older with typical symptoms, perimenopause or menopause is usually diagnosed from the clinical history because hormone levels fluctuate. Testing may still be appropriate when the age, symptoms, menstrual history or another possible diagnosis makes the situation less clear.</p>',
    },
    {
      question: 'Do I need a referral for hormone testing?',
      answer: '<p>No family doctor or specialist referral is required. After reviewing the clinical question, I can arrange appropriate private blood testing or, when justified, a specialized collection kit. Costs are reviewed before proceeding.</p>',
    },
  ]} />

  <section class="bg-emerald-950 py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="mb-6 text-3xl font-medium text-white sm:text-4xl font-serif">Discuss Whether Hormone Testing Is Appropriate</h2>
        <p class="mb-8 text-lg leading-relaxed text-white/90">Book an initial consultation to review your concerns, previous results and which hormone markers or testing method, if any, would provide useful information.</p>
        <CTAButton source="hormone-testing-cta" />
      </div>
    </div>
  </section>
</BaseLayout>
