---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import BookingButton from '../components/BookingButton.astro';
import FAQSection from '../components/FAQSection.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((page) => ({
    params: { slug: page.slug },
    props: page,
  }));
}

type Props = CollectionEntry<'pages'>;

const page = Astro.props;
const { Content } = await page.render();

// SEO preparation
const seoTitle = page.data.seo?.title || page.data.title;
const seoDescription = page.data.seo?.description || page.data.description;
const focusKeyword = page.data.seo?.focusKeyword || '';

const isTreatment = page.data.type === 'treatment';
const hubHref = isTreatment ? '/services' : '/conditions';
const hubLabel = isTreatment ? 'Services' : 'Conditions';

// Format modified date if exists
const modifiedDate = page.data.modifiedDate
  ? new Date(page.data.modifiedDate).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    })
  : null;
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  focusKeyword={focusKeyword}
>
  <HeroSection title={page.data.title} compact textOnly>
    <nav slot="breadcrumb" class="text-emerald-300 text-sm mb-4" aria-label="Breadcrumb">
      <a href={hubHref} class="hover:text-white transition-colors">{hubLabel}</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <span class="text-white">{page.data.title}</span>
    </nav>
    <p>{page.data.description}</p>
  </HeroSection>

  <!-- Page Content -->
  <article class="py-16 lg:py-24 bg-white">
    <div class="section-shell">
      <div class="max-w-4xl mx-auto">

        {modifiedDate && (
          <p class="text-sm text-slate-500 mb-8">Last updated {modifiedDate}</p>
        )}

        <div class="prose max-w-[70ch]">
          <Content />
        </div>

        <!-- Page Footer -->
        <footer class="mt-12 pt-8 border-t border-slate-200">

          <!-- Quick Links Box -->
          <div class="bg-emerald-50/50 border border-emerald-100 rounded-2xl p-8 mb-8 shadow-sm">
            <div class="flex items-start space-x-4">
              <div class="w-16 h-16 bg-emerald-900 rounded-full flex items-center justify-center flex-shrink-0 shadow-lg">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-serif font-bold text-emerald-950 mb-2">
                  {isTreatment ? 'Interested in This Treatment?' : 'Want Help With This Condition?'}
                </h3>
                <p class="text-slate-600 mb-4">
                  {isTreatment
                    ? 'Dr. MacLeod offers personalized consultations to discuss how this treatment approach might benefit your specific health concerns.'
                    : 'Dr. MacLeod offers personalized consultations to discuss how naturopathic treatment might help your specific situation.'}
                </p>
                <div class="flex flex-col sm:flex-row gap-3">
                  <BookingButton
                    text="Book Online"
                    variant="secondary"
                    size="sm"
                    source={`page-${page.slug}`}
                  />
                  <a
                    href={hubHref}
                    class="inline-flex items-center text-emerald-800 hover:text-emerald-900 font-medium text-sm"
                  >
                    View All {hubLabel}
                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Navigation -->
          <div class="flex justify-between items-center">
            <a
              href={hubHref}
              class="inline-flex items-center text-emerald-800 hover:text-emerald-900 font-medium"
            >
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
              </svg>
              Back to {hubLabel}
            </a>

            <div class="text-sm text-slate-500">
              Have questions?
              <a href="/contact/" class="text-emerald-800 hover:text-emerald-900 font-medium ml-1">
                Contact Dr. MacLeod
              </a>
            </div>
          </div>
        </footer>
      </div>
    </div>
  </article>

  {page.data.faq && page.data.faq.length > 0 && (
    <FAQSection items={page.data.faq} />
  )}

  <!-- CTA Section -->
  <section class="bg-emerald-950 py-16 lg:py-24">
    <div class="section-shell">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-serif font-bold text-white mb-6">Ready to Start Your Health Journey?</h2>
        <p class="text-lg sm:text-xl text-white/90 mb-8 leading-relaxed">
          Schedule a consultation to learn how naturopathic medicine can support your health goals.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <BookingButton
            text="Book Online"
            size="lg"
            source={`page-cta-${page.slug}`}
          />
          <a
            href={hubHref}
            class="border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-emerald-950 active:scale-[0.98] transition-colors inline-flex items-center justify-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-400 focus-visible:ring-offset-2 focus-visible:ring-offset-emerald-950"
          >
            View All {hubLabel}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
