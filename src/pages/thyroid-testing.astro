---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CTAButton from '../components/CTAButton.astro';
import FAQSection from '../components/FAQSection.astro';
import RelatedCare from '../components/RelatedCare.astro';
import { Check, Info } from '@lucide/astro';

const coreTests = [
  {
    abbreviation: 'TSH',
    name: 'Thyroid-stimulating hormone',
    description: 'TSH is produced by the pituitary gland and signals the thyroid to produce hormone. It is usually the initial blood test used to assess suspected primary thyroid dysfunction.',
  },
  {
    abbreviation: 'FT4',
    name: 'Free thyroxine',
    description: 'T4 is the principal hormone released by the thyroid. Free T4 measures the portion that is not bound to proteins and is available to tissues or for conversion to T3.',
  },
  {
    abbreviation: 'FT3',
    name: 'Free triiodothyronine',
    description: 'T3 is the more biologically active thyroid hormone. Free T3 is particularly useful in some evaluations of hyperthyroidism, but it is not required in every assessment of hypothyroidism.',
  },
];

const resultPatterns = [
  {
    pattern: 'TSH above range + FT4 below range',
    meaning: 'A biochemical pattern consistent with primary hypothyroidism.',
  },
  {
    pattern: 'TSH above range + FT4 within range',
    meaning: 'A pattern described as subclinical hypothyroidism. Follow-up depends on the degree and persistence of the change, symptoms and clinical context.',
  },
  {
    pattern: 'TSH below range + FT4 and/or FT3 above range',
    meaning: 'A biochemical pattern consistent with hyperthyroidism or thyrotoxicosis that requires assessment of the cause.',
  },
  {
    pattern: 'Results that do not follow an expected pattern',
    meaning: 'Medication, supplements, acute illness, laboratory interference and pituitary conditions are among the factors that may need to be considered.',
  },
];

const broaderTestingReasons = [
  'Previous thyroid results that were abnormal, borderline or inconsistent',
  'Persistent thyroid-related symptoms that require further clinical assessment',
  'A personal or family history of thyroid disease or autoimmune conditions',
  'Ongoing symptoms while taking thyroid medication',
  'Fertility, pregnancy or postpartum concerns, where interpretation is different',
  'Fluctuating thyroid levels or suspected pituitary disease',
];
---

<BaseLayout
  title="Thyroid Blood Testing in Halifax | TSH, T4, T3 & Antibodies"
  description="Thyroid blood testing in Halifax, including TSH, Free T4, Free T3 and thyroid antibodies when appropriate. Testing is available without a family doctor requisition."
  focusKeyword="thyroid testing Halifax"
>
  <HeroSection
    title="Complete Thyroid Testing"
    compact
    image={{ src: '/images/lab-testing/thyroid-panel.webp', alt: 'Thyroid gland anatomy', aspect: 'video' }}
  >
    <p>
      Thyroid blood testing can include TSH, free T4, free T3 and thyroid antibodies when clinically appropriate. Testing can be arranged <strong class="text-white">without a family doctor requisition</strong>, with the results reviewed in the context of your symptoms, history and medications.
    </p>
  </HeroSection>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div>
            <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">A clinical, stepwise approach</p>
            <h2 class="mb-5 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">Testing is selected for the question being asked</h2>
            <p class="text-lg leading-relaxed text-slate-600">
              A larger panel is not automatically a better panel. TSH is an informative first-line test for most people. Free thyroid hormones and antibodies are added when the initial result, medical history or clinical circumstances make them useful.
            </p>
          </div>

          <ol class="divide-y divide-emerald-100 rounded-2xl border border-emerald-200 bg-emerald-50/60 px-6 sm:px-8">
            <li class="grid grid-cols-[2.5rem_1fr] gap-4 py-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-950 text-sm font-semibold text-white">1</span>
              <div>
                <h3 class="mb-1 font-semibold text-emerald-950">Begin with context</h3>
                <p class="leading-relaxed text-slate-600">Symptoms, previous results, medications, pregnancy status and relevant health history affect which tests are appropriate.</p>
              </div>
            </li>
            <li class="grid grid-cols-[2.5rem_1fr] gap-4 py-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-950 text-sm font-semibold text-white">2</span>
              <div>
                <h3 class="mb-1 font-semibold text-emerald-950">Choose the markers</h3>
                <p class="leading-relaxed text-slate-600">Testing may begin with TSH or include additional markers when there is a clear reason to measure them.</p>
              </div>
            </li>
            <li class="grid grid-cols-[2.5rem_1fr] gap-4 py-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-950 text-sm font-semibold text-white">3</span>
              <div>
                <h3 class="mb-1 font-semibold text-emerald-950">Interpret the pattern</h3>
                <p class="leading-relaxed text-slate-600">Results are considered together and compared with the laboratory's reference intervals, not interpreted as isolated numbers.</p>
              </div>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-emerald-50 py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-6xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Core thyroid function tests</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">What the main markers measure</h2>
          <p class="text-lg leading-relaxed text-slate-600">Each test describes a different part of the relationship between the pituitary gland, the thyroid and circulating thyroid hormones.</p>
        </div>

        <div class="grid gap-5 lg:grid-cols-3">
          {coreTests.map((test) => (
            <article class="rounded-2xl border border-emerald-200 bg-white p-7 shadow-sm">
              <div class="mb-6 flex items-center gap-4">
                <span class="flex h-12 min-w-12 items-center justify-center rounded-xl bg-emerald-950 px-2 text-sm font-bold text-white">{test.abbreviation}</span>
                <h3 class="text-xl font-semibold leading-tight text-emerald-950">{test.name}</h3>
              </div>
              <p class="leading-relaxed text-slate-600">{test.description}</p>
            </article>
          ))}
        </div>

        <div class="mt-8 rounded-2xl border border-emerald-200 bg-white p-7 sm:p-8">
          <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr]">
            <div>
              <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Thyroid antibodies</p>
              <h3 class="mb-3 text-2xl font-medium text-emerald-950 font-serif">Markers of autoimmunity</h3>
              <p class="leading-relaxed text-slate-600">
                Antibody results can help identify an autoimmune cause of thyroid disease. They do not, by themselves, measure thyroid function, the amount of thyroid damage or the severity of a person's symptoms.
              </p>
            </div>
            <div class="grid gap-5 sm:grid-cols-2">
              <div class="rounded-xl bg-emerald-50 p-6">
                <p class="mb-2 font-semibold text-emerald-950">TPO antibodies</p>
                <p class="text-sm leading-relaxed text-slate-600">Thyroid peroxidase antibodies are commonly associated with autoimmune thyroid disease, particularly Hashimoto thyroiditis.</p>
              </div>
              <div class="rounded-xl bg-emerald-50 p-6">
                <p class="mb-2 font-semibold text-emerald-950">Thyroglobulin antibodies</p>
                <p class="text-sm leading-relaxed text-slate-600">Thyroglobulin antibodies are another marker of thyroid autoimmunity. Their significance depends on the reason for testing and the other thyroid results.</p>
              </div>
            </div>
          </div>
          <div class="mt-6 flex gap-3 border-t border-emerald-100 pt-6 text-sm leading-relaxed text-slate-600">
            <Info class="mt-0.5 h-5 w-5 flex-none text-emerald-700" aria-hidden="true" />
            <p>Antibody testing is not required for everyone and repeat measurements often do not add useful information once thyroid autoimmunity has been established.</p>
          </div>
        </div>

        <aside class="mt-5 rounded-2xl border border-slate-200 bg-slate-50 p-7 sm:p-8" aria-labelledby="reverse-t3-heading">
          <div class="grid gap-4 md:grid-cols-[10rem_1fr] md:items-start">
            <h3 id="reverse-t3-heading" class="text-xl font-semibold text-slate-900">Reverse T3</h3>
            <div class="space-y-3 leading-relaxed text-slate-600">
              <p>Reverse T3 is an inactive metabolite produced from T4. Its level can change during acute illness and other physiological states.</p>
              <p>It is not part of standard initial thyroid testing and should not be presented as a routine measure of thyroid function. If ordered, its limited and context-dependent role should be discussed before testing.</p>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Understanding results</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">Patterns matter more than a single number</h2>
          <p class="text-lg leading-relaxed text-slate-600">
            Laboratory reference intervals are specific to the testing method and population. Results are interpreted as a pattern and in the context of symptoms, health history and factors that may affect the measurement.
          </p>
        </div>

        <div class="overflow-hidden rounded-2xl border border-emerald-200">
          {resultPatterns.map((result, index) => (
            <div class:list={['grid gap-2 p-6 sm:grid-cols-[0.9fr_1.1fr] sm:gap-8 sm:p-7', index !== resultPatterns.length - 1 && 'border-b border-emerald-100']}>
              <p class="font-semibold text-emerald-950">{result.pattern}</p>
              <p class="leading-relaxed text-slate-600">{result.meaning}</p>
            </div>
          ))}
        </div>

        <div class="mt-6 rounded-xl bg-amber-50 p-5 text-sm leading-relaxed text-amber-950 ring-1 ring-amber-200">
          High-dose biotin supplements can interfere with some thyroid laboratory tests. Medication and supplement use should be reviewed before blood collection; medications should not be stopped unless specifically instructed.
        </div>
      </div>
    </div>
  </section>

  <section class="bg-emerald-950 py-16 lg:py-20">
    <div class="section-shell">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
        <div>
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-300">Selecting additional markers</p>
          <h2 class="mb-5 text-3xl font-medium text-white sm:text-4xl font-serif">When broader testing may be considered</h2>
          <p class="leading-relaxed text-emerald-50/85">These circumstances can affect the choice of tests, but none automatically means that every thyroid marker is required.</p>
        </div>
        <ul class="grid gap-3 sm:grid-cols-2">
          {broaderTestingReasons.map((reason) => (
            <li class="flex gap-3 rounded-xl border border-white/15 bg-white/10 p-4 text-sm leading-relaxed text-white">
              <Check class="mt-0.5 h-5 w-5 flex-none text-emerald-300" aria-hidden="true" />
              <span>{reason}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Private testing in Nova Scotia</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">How the testing process works</h2>
          <p class="text-lg leading-relaxed text-slate-600">A family doctor or specialist referral is not required. Testing is selected and reviewed through the naturopathic appointment process.</p>
        </div>

        <ol class="grid gap-5 md:grid-cols-3">
          <li class="rounded-2xl border border-emerald-200 p-6">
            <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 font-semibold text-emerald-800">1</span>
            <h3 class="mb-2 text-lg font-semibold text-emerald-950">Clinical review</h3>
            <p class="text-sm leading-relaxed text-slate-600">Your concerns, previous results and relevant history are reviewed to determine which markers are appropriate.</p>
          </li>
          <li class="rounded-2xl border border-emerald-200 p-6">
            <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 font-semibold text-emerald-800">2</span>
            <h3 class="mb-2 text-lg font-semibold text-emerald-950">Requisition and collection</h3>
            <p class="text-sm leading-relaxed text-slate-600">A private laboratory requisition is provided. Test costs depend on the selected markers and are confirmed before proceeding.</p>
          </li>
          <li class="rounded-2xl border border-emerald-200 p-6">
            <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 font-semibold text-emerald-800">3</span>
            <h3 class="mb-2 text-lg font-semibold text-emerald-950">Results and follow-up</h3>
            <p class="text-sm leading-relaxed text-slate-600">The results are reviewed together, with recommendations based on the findings and the limits of what the tests can establish.</p>
          </li>
        </ol>

        <div class="mt-8 rounded-2xl bg-emerald-50 p-6">
          <p class="text-sm leading-relaxed text-slate-600">Laboratory testing ordered through a naturopathic doctor is not covered by MSI. Some extended health plans may cover naturopathic appointments, but laboratory coverage varies.</p>
        </div>
      </div>
    </div>
  </section>

  <RelatedCare
    title="Related Testing"
    hubHref="/lab-testing/"
    hubLabel="Lab Testing"
    links={[
      { title: 'Hormone Testing', href: '/hormone-testing/' },
      { title: 'Nutrient Status', href: '/nutrient-testing/' },
      { title: 'Wellness Blood Work', href: '/wellness-blood-work/' },
    ]}
  />

  <FAQSection bg="white" items={[
    {
      question: "Do I need a doctor's requisition for thyroid testing?",
      answer: "<p>You do not need a family doctor or specialist referral. As a naturopathic doctor, I can provide a private laboratory requisition after determining which tests are appropriate.</p>",
    },
    {
      question: 'Do I need every test listed on this page?',
      answer: '<p>No. The choice of markers depends on the clinical question, previous results, symptoms, medications and health history. For many people, testing begins with TSH and additional markers are added only when they are likely to provide useful information.</p>',
    },
    {
      question: 'Is thyroid testing covered by MSI?',
      answer: '<p>Laboratory testing ordered through a naturopathic doctor is not covered by MSI and is paid privately. Test costs depend on the markers selected and are reviewed before the requisition is completed.</p>',
    },
    {
      question: 'How should I prepare for thyroid blood testing?',
      answer: '<p>Preparation depends on the tests and medications involved. Please provide a complete list of medications and supplements, including biotin. Do not stop medication unless you have been specifically instructed to do so. Any timing or fasting instructions will be discussed before collection.</p>',
    },
    {
      question: 'What does a positive thyroid antibody result mean?',
      answer: '<p>A positive antibody result can support an autoimmune cause of thyroid disease, but it does not by itself show how well the thyroid is functioning, how severe symptoms should be or whether treatment is required. It is interpreted with TSH, thyroid hormone levels and the clinical history.</p>',
    },
  ]} />

  <section class="bg-emerald-950 py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="mb-6 text-3xl font-medium text-white sm:text-4xl font-serif">Discuss Whether Thyroid Testing Is Appropriate</h2>
        <p class="mb-8 text-lg leading-relaxed text-white/90">Book an initial consultation to review your concerns, previous results and which thyroid markers, if any, would provide useful information.</p>
        <CTAButton source="thyroid-testing-cta" />
      </div>
    </div>
  </section>
</BaseLayout>
