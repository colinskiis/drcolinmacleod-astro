---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import BookingButton from '../components/BookingButton.astro';
import { ChevronRight } from '@lucide/astro';

const resources = [
  {
    title: 'New Patient Guide',
    description: 'What to expect at your first visit, what to bring and how to book.',
    href: '/new-patients/',
  },
  {
    title: 'Private Blood Testing & Lab Work',
    description: 'Comprehensive blood work without a family doctor requisition.',
    href: '/lab-testing/',
  },
  {
    title: 'IV Therapy',
    description: 'IV nutrient therapy for energy, immune support and recovery.',
    href: '/iv-therapy/',
  },
  {
    title: 'Prolotherapy',
    description: 'Regenerative injection therapy for joint pain and ligament injuries.',
    href: '/prolotherapy/',
  },
  {
    title: 'Health Articles',
    description: 'Evidence-based articles on conditions, treatments and natural health.',
    href: '/articles/',
  },
  {
    title: 'Contact',
    description: 'Hours, location at Optimal Wellbeing Clinic and how to reach us.',
    href: '/contact/',
  },
];
---

<BaseLayout
  title="Patient Resources"
  description="Patient guides and resources for Dr. Colin MacLeod, ND at Optimal Wellbeing Clinic in Bedford, NS. New patients, lab testing, IV therapy, prolotherapy and booking."
  focusKeyword="patient resources naturopathic Bedford NS"
>
  <HeroSection title="Patient Resources" centered compact>
    <p>
      Guides and helpful links for patients at Optimal Wellbeing Clinic. If you arrived here from an older patient-info link, use the resources below to find current information.
    </p>
  </HeroSection>

  <section class="py-12 lg:py-20 bg-white">
    <div class="section-shell">
      <div class="max-w-3xl mx-auto reveal">
        <div class="grid gap-3">
          {resources.map((item) => (
            <a
              href={item.href}
              class="group flex flex-col gap-1 p-4 rounded-xl border border-emerald-50 hover:border-emerald-200 hover:bg-emerald-50/40 transition-all focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2"
            >
              <span class="flex items-center gap-2 font-semibold text-emerald-950 group-hover:text-emerald-700 transition-colors">
                <ChevronRight class="w-4 h-4 text-emerald-500 flex-shrink-0 group-hover:translate-x-0.5 transition-transform duration-200" aria-hidden="true" />
                {item.title}
              </span>
              <span class="text-sm text-slate-500 pl-6">{item.description}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-emerald-950 py-16 lg:py-24">
    <div class="section-shell text-center">
      <h2 class="text-3xl sm:text-4xl font-serif font-medium text-white mb-6">Ready to Book?</h2>
      <p class="text-lg sm:text-xl text-white/90 mb-8 max-w-3xl mx-auto leading-relaxed">
        Schedule online or call the clinic. Dr. MacLeod sees patients at Optimal Wellbeing Clinic on the Bedford Highway.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <BookingButton text="Book Online" variant="hero" size="lg" source="patient-resources" />
        <a
          href="tel:+19024064424"
          class="inline-flex items-center gap-3 px-6 py-3 rounded-full border border-white/30 text-white hover:bg-white/10 hover:-translate-y-0.5 transition-all font-semibold text-base focus:outline-none focus:ring-2 focus:ring-emerald-400 focus:ring-offset-2 focus:ring-offset-emerald-950"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
          (902) 406-4424
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
