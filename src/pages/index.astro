---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingButton from '../components/BookingButton.astro';
import FAQSection from '../components/FAQSection.astro';
import { Phone, FlaskConical, ChevronRight, ArrowRight, Microscope, HeartPulse, BookOpen } from '@lucide/astro';

// Conditions (top 3 for nav hub)
const conditions = [
  { title: 'Low Back Pain', href: '/low-back-pain/' },
  { title: 'Osteoarthritis', href: '/osteoarthritis/' },
  { title: 'Fibromyalgia', href: '/fibromyalgia/' },
];

// Articles (top 3 for nav hub - short titles to fit on one line)
const articles = [
  { title: 'Better Sleep', href: '/articles/sleep-optimization-evidence-based-strategies/' },
  { title: 'Gut Health', href: '/articles/digestive-health-natural-approaches/' },
  { title: 'Anxiety', href: '/articles/natural-anxiety-management/' },
];

// Blood Tests (top 3 for nav hub)
const bloodTests = [
  { title: 'Thyroid Panel', href: '/thyroid-testing/' },
  { title: 'Hormone Panel', href: '/hormone-testing/' },
  { title: 'Vitamin D', href: '/nutrient-testing/' },
];

// All services for Services section
const allServices = [
  { title: 'Laboratory Testing', description: 'Access private blood work, in-office collection and broader testing without a family-doctor requisition.', img: '/images/lab-testing/in-office-blood-draw.webp', href: '/lab-testing/' },
  { title: 'IV Therapy', description: 'Individualized intravenous nutrient therapy with clinical screening and monitoring.', img: '/images/treatments/iv-patient-woman.webp', href: '/iv-therapy/' },
  { title: 'Prolotherapy', description: 'An injection-based option used in the management of selected joint and tendon concerns.', img: '/images/treatments/prolotherapy-knee-injection.webp', href: '/prolotherapy/' },
];

const featuredService = allServices[0];
const secondaryServices = allServices.slice(1);

// FAQ data for schema markup
const faqItems = [
  {
    question: "Can naturopathic doctors order blood tests?",
    answer: "Yes. As a naturopathic doctor, Dr. MacLeod can order a comprehensive range of blood and laboratory tests through private labs. This includes thyroid panels, hormone levels, nutrient status, inflammatory markers and more. Private testing often means broader panels and faster turnaround compared to the public system, giving us a clear picture of your health."
  },
  {
    question: "Is naturopathic medicine covered by insurance?",
    answer: "Yes, most extended health insurance plans cover naturopathic visits. We offer direct billing for many major insurers to make the process convenient for you."
  },
  {
    question: "Do you work alongside my family doctor?",
    answer: "Absolutely. Naturopathic medicine is most effective as part of a coordinated care approach. I regularly share findings and treatment summaries with family doctors and specialists when patients consent. While naturopathic doctors don't have direct referral privileges in Nova Scotia, I actively communicate with other healthcare providers to help facilitate appropriate referrals where needed."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<BaseLayout
  title="Home"
  description="Dr. Colin MacLeod, ND in Halifax, NS. Evidence-based naturopathic medicine, IV therapy, prolotherapy, acupuncture, nutrition."
  focusKeyword="Dr. Colin MacLeod, ND, Halifax naturopathic doctor, IV therapy, prolotherapy, acupuncture"
  image="/images/og-image.jpg"
>
  <!-- Homepage hero -->
  <section class="hero-gradient -mt-24 pt-24 relative overflow-hidden">
    <!-- Ambient background shapes -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute -top-32 -right-32 w-96 h-96 bg-emerald-800/20 rounded-full blur-3xl"></div>
      <div class="absolute top-1/2 -left-24 w-64 h-64 bg-emerald-700/15 rounded-full blur-2xl"></div>
      <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-emerald-600/10 rounded-full blur-3xl"></div>
    </div>

    <div class="section-shell relative z-10 py-10 sm:py-14 lg:py-20">
      <div class="grid items-center gap-8 lg:grid-cols-[1.08fr_0.92fr] lg:gap-16">
        <div class="space-y-6 lg:space-y-7">
          <!-- Compact mobile portrait -->
          <div class="flex justify-center lg:hidden animate-fade-in-up">
            <a href="/about/" aria-label="About Dr. Colin MacLeod, ND" class="block h-28 w-24 overflow-hidden rounded-2xl border-2 border-white/20 shadow-xl shadow-black/25 transition-all duration-300 hover:border-white/40">
              <picture>
                <source srcset="/images/general/colin-hero.avif" type="image/avif" />
                <source srcset="/images/general/colin-hero.webp" type="image/webp" />
                <img
                  src="/images/general/Dr-colin-macleod-ND.jpeg"
                  alt="Dr. Colin MacLeod, ND"
                  class="h-full w-full object-cover object-top"
                  width="609"
                  height="1050"
                  loading="eager"
                />
              </picture>
            </a>
          </div>

          <div class="space-y-4 text-center lg:text-left">
            <p class="text-xs font-medium uppercase tracking-[0.2em] text-emerald-300 sm:text-sm animate-fade-in-up">
              Halifax Naturopathic Doctor
            </p>

            <h1 class="text-[2.55rem] font-medium font-serif leading-[1.06] tracking-tight text-white sm:text-5xl lg:text-6xl animate-fade-in-up animate-delay-100">
              Look beyond symptoms. Build a plan for better health.
            </h1>

            <p class="mx-auto max-w-xl text-base leading-relaxed text-emerald-100 sm:text-lg lg:mx-0 animate-fade-in-up animate-delay-200">
              Naturopathic care in Bedford, serving Halifax, with private lab testing, IV therapy and prolotherapy coordinated around your broader healthcare team.
            </p>
          </div>

          <div class="flex flex-col items-center justify-center gap-3 sm:flex-row lg:justify-start animate-fade-in-up animate-delay-300">
            <BookingButton text="Book Online" variant="hero" size="lg" source="hero" />
            <a
              href="/lab-testing/"
              class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full border border-white/25 bg-white/5 px-6 py-3 font-medium text-white transition-all hover:-translate-y-0.5 hover:border-white/40 hover:bg-white/10"
            >
              <FlaskConical class="h-4 w-4 text-emerald-300" aria-hidden="true" />
              Explore Lab Testing
              <ChevronRight class="h-4 w-4 text-emerald-300" aria-hidden="true" />
            </a>
          </div>

          <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm text-emerald-200 lg:justify-start animate-fade-in-up animate-delay-400">
            <a href="tel:+19024064424" class="inline-flex items-center gap-2 transition-colors hover:text-white">
              <Phone class="h-4 w-4" aria-hidden="true" />
              (902) 406-4424
            </a>
            <a href="/new-patients/" class="text-emerald-300 underline underline-offset-2 transition-colors hover:text-white">First visit? Learn what to expect →</a>
          </div>
        </div>

        <!-- Desktop portrait -->
        <div class="relative hidden justify-center lg:flex">
          <div class="relative group">
            <a href="/about/" aria-label="About Dr. Colin MacLeod, ND" class="block h-[27rem] w-[21rem] overflow-hidden rounded-[2rem] border-2 border-white/20 shadow-2xl shadow-black/30 transition-all duration-300 hover:scale-[1.01] hover:border-white/40 hover:shadow-black/45 xl:h-[30rem] xl:w-[23rem]">
                <picture>
                  <source srcset="/images/general/colin-hero.avif" type="image/avif" />
                  <source srcset="/images/general/colin-hero.webp" type="image/webp" />
                  <img
                    src="/images/general/Dr-colin-macleod-ND.jpeg"
                    alt="Dr. Colin MacLeod, ND"
                    class="h-full w-full object-cover object-top"
                    width="609"
                    height="1050"
                    loading="eager"
                  />
                </picture>
            </a>
            <span class="pointer-events-none absolute -bottom-9 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full bg-emerald-950/90 px-4 py-1.5 text-sm font-medium text-white opacity-0 transition-opacity duration-200 group-hover:opacity-100">About Dr. MacLeod</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="section-shell">
      <div class="text-center max-w-3xl mx-auto mb-10 lg:mb-14 space-y-4 reveal">
        <h2 class="text-3xl sm:text-4xl font-serif font-medium text-emerald-950 tracking-tight">Services</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">Private testing and treatments tailored to your concerns, health history and goals.</p>
      </div>

      <div class="space-y-6 sm:space-y-8 reveal reveal-delay-100">
        <!-- Featured laboratory testing -->
        <a href={featuredService.href} class="group grid overflow-hidden rounded-3xl border border-emerald-100 bg-emerald-50 shadow-xl shadow-emerald-900/5 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-emerald-900/10 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 sm:grid-cols-[1.15fr_0.85fr] sm:items-stretch">
          <div class="aspect-[16/10] overflow-hidden sm:aspect-auto sm:min-h-[22rem] xl:aspect-[4/3] xl:min-h-0">
            <img src={featuredService.img} alt="Dr. Colin MacLeod performing an in-office blood draw" class="h-full w-full object-cover object-[center_20%] transition-transform duration-500 group-hover:scale-[1.03] sm:object-center xl:object-[center_20%]" width="800" height="600" loading="lazy" />
          </div>
          <div class="flex flex-col justify-center p-7 sm:p-9 lg:p-12">
            <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700">Private laboratory access</p>
            <h3 class="mb-4 text-3xl font-serif font-medium leading-tight text-emerald-950 transition-colors group-hover:text-emerald-700 sm:text-4xl">{featuredService.title}</h3>
            <p class="mb-6 text-base leading-relaxed text-slate-600 sm:text-lg">{featuredService.description}</p>
            <span class="inline-flex items-center gap-1.5 font-semibold text-emerald-800">
              Explore Lab Testing
              <ChevronRight class="h-4 w-4 transition-transform group-hover:translate-x-0.5" aria-hidden="true" />
            </span>
          </div>
        </a>

        <!-- Secondary services retain authentic imagery at every breakpoint -->
        <div class="grid gap-4 sm:grid-cols-2 sm:gap-8">
          {secondaryServices.map((item) => (
            <a href={item.href} class="group grid min-h-32 grid-cols-[7.5rem_1fr] overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-lg shadow-emerald-900/5 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-emerald-900/10 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 sm:block sm:rounded-3xl">
              <div class="overflow-hidden sm:aspect-[4/3]">
                <img
                  src={item.img}
                  alt={item.title}
                  class:list={[
                    'h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]',
                    item.title === 'Prolotherapy' ? 'object-top' : 'object-center',
                  ]}
                  width="800"
                  height="450"
                  loading="lazy"
                />
              </div>
              <div class="flex flex-col justify-center p-5 sm:p-7">
                <h3 class="mb-2 text-xl font-serif font-medium leading-tight text-emerald-950 transition-colors group-hover:text-emerald-700 sm:text-2xl">{item.title}</h3>
                <p class="hidden text-base leading-relaxed text-slate-600 sm:block">{item.description}</p>
                <span class="mt-2 inline-flex items-center gap-1 text-sm font-semibold text-emerald-700 sm:mt-4">
                  Learn more <ChevronRight class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" aria-hidden="true" />
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="text-center mt-10 sm:mt-16">
        <a
          href="/services/"
          class="inline-flex items-center bg-emerald-900 text-white px-10 py-4 rounded-full text-base font-medium tracking-wide hover:bg-emerald-800 hover:-translate-y-0.5 transition-all duration-200 shadow-lg shadow-emerald-900/20 hover:shadow-xl hover:shadow-emerald-900/25"
        >
          View All Services
        </a>
      </div>
    </div>
  </section>

  <!-- Navigation Hub -->
  <section class="py-12 lg:py-16 bg-emerald-50">
    <div class="section-shell">
      <div class="text-center max-w-3xl mx-auto mb-8 lg:mb-10 space-y-3 reveal">
        <h2 class="text-3xl sm:text-4xl font-serif font-medium text-emerald-950">Explore Your Options</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">Start with blood testing, a health concern or evidence-based articles.</p>
      </div>

      <div class="space-y-4 reveal">

        <!-- Card 1: Blood Tests -->
        <div class="bg-white rounded-2xl shadow-sm ring-1 ring-emerald-200 overflow-hidden">
          <!-- Card header row -->
          <div class="flex items-center justify-between px-5 pt-5 pb-3 lg:px-7 lg:pt-6 lg:pb-4">
            <a href="/lab-testing/" class="group flex items-center gap-3 min-w-0">
              <span class="flex-shrink-0 flex items-center justify-center w-9 h-9 rounded-xl bg-emerald-100 text-emerald-700 group-hover:bg-emerald-200 transition-colors">
                <Microscope class="w-5 h-5" stroke-width={1.75} aria-hidden="true" />
              </span>
              <span class="text-xl lg:text-2xl font-serif font-medium text-emerald-900 tracking-tight group-hover:text-emerald-700 transition-colors">Blood Tests</span>
              <ChevronRight class="w-4 h-4 text-emerald-400 flex-shrink-0 group-hover:text-emerald-600 group-hover:translate-x-0.5 transition-all" aria-hidden="true" />
            </a>
            <a href="/lab-testing/" class="hidden lg:inline-flex items-center gap-1.5 text-sm font-medium text-emerald-700 hover:text-emerald-900 transition-colors flex-shrink-0 ml-4">
              See all
              <ArrowRight class="w-3.5 h-3.5" aria-hidden="true" />
            </a>
          </div>
          <!-- Item links -->
          <div class="flex flex-col lg:flex-row lg:items-center border-t border-emerald-100 divide-y divide-emerald-100 lg:divide-y-0 lg:divide-x lg:divide-emerald-100">
            {bloodTests.map((test) => (
              <a href={test.href} class="group flex items-center gap-2 px-5 py-3 lg:px-7 lg:py-3 text-base text-emerald-950 hover:text-emerald-700 hover:bg-emerald-50/60 transition-all flex-1">
                <ChevronRight class="w-4 h-4 text-emerald-300 flex-shrink-0 group-hover:text-emerald-500 group-hover:translate-x-0.5 transition-all" aria-hidden="true" />
                {test.title}
              </a>
            ))}
            <a href="/lab-testing/" class="lg:hidden group flex items-center gap-2 px-5 py-3 text-sm font-medium text-emerald-700 hover:text-emerald-900 hover:bg-emerald-50/60 transition-all">
              <ArrowRight class="w-4 h-4 flex-shrink-0" aria-hidden="true" />
              See all blood tests
            </a>
          </div>
        </div>

        <!-- Card 2: Conditions -->
        <div class="bg-white rounded-2xl shadow-sm ring-1 ring-emerald-200 overflow-hidden">
          <div class="flex items-center justify-between px-5 pt-5 pb-3 lg:px-7 lg:pt-6 lg:pb-4">
            <a href="/conditions/" class="group flex items-center gap-3 min-w-0">
              <span class="flex-shrink-0 flex items-center justify-center w-9 h-9 rounded-xl bg-emerald-100 text-emerald-800 group-hover:bg-emerald-200 transition-colors">
                <HeartPulse class="w-5 h-5" stroke-width={1.75} aria-hidden="true" />
              </span>
              <span class="text-xl lg:text-2xl font-serif font-medium text-emerald-900 tracking-tight group-hover:text-emerald-700 transition-colors">Conditions</span>
              <ChevronRight class="w-4 h-4 text-emerald-400 flex-shrink-0 group-hover:text-emerald-600 group-hover:translate-x-0.5 transition-all" aria-hidden="true" />
            </a>
            <a href="/conditions/" class="hidden lg:inline-flex items-center gap-1.5 text-sm font-medium text-emerald-700 hover:text-emerald-900 transition-colors flex-shrink-0 ml-4">
              See all
              <ArrowRight class="w-3.5 h-3.5" aria-hidden="true" />
            </a>
          </div>
          <div class="flex flex-col lg:flex-row lg:items-center border-t border-emerald-100 divide-y divide-emerald-100 lg:divide-y-0 lg:divide-x lg:divide-emerald-100">
            {conditions.map((condition) => (
              <a href={condition.href} class="group flex items-center gap-2 px-5 py-3 lg:px-7 lg:py-3 text-base text-emerald-950 hover:text-emerald-700 hover:bg-emerald-50/60 transition-all flex-1">
                <ChevronRight class="w-4 h-4 text-emerald-300 flex-shrink-0 group-hover:text-emerald-500 group-hover:translate-x-0.5 transition-all" aria-hidden="true" />
                {condition.title}
              </a>
            ))}
            <a href="/conditions/" class="lg:hidden group flex items-center gap-2 px-5 py-3 text-sm font-medium text-emerald-700 hover:text-emerald-900 hover:bg-emerald-50/60 transition-all">
              <ArrowRight class="w-4 h-4 flex-shrink-0" aria-hidden="true" />
              See all conditions
            </a>
          </div>
        </div>

        <!-- Card 3: Articles -->
        <div class="bg-white rounded-2xl shadow-sm ring-1 ring-emerald-200 overflow-hidden">
          <div class="flex items-center justify-between px-5 pt-5 pb-3 lg:px-7 lg:pt-6 lg:pb-4">
            <a href="/articles/" class="group flex items-center gap-3 min-w-0">
              <span class="flex-shrink-0 flex items-center justify-center w-9 h-9 rounded-xl bg-emerald-100 text-emerald-900 group-hover:bg-emerald-200 transition-colors">
                <BookOpen class="w-5 h-5" stroke-width={1.75} aria-hidden="true" />
              </span>
              <span class="text-xl lg:text-2xl font-serif font-medium text-emerald-900 tracking-tight group-hover:text-emerald-700 transition-colors">Articles</span>
              <ChevronRight class="w-4 h-4 text-emerald-400 flex-shrink-0 group-hover:text-emerald-600 group-hover:translate-x-0.5 transition-all" aria-hidden="true" />
            </a>
            <a href="/articles/" class="hidden lg:inline-flex items-center gap-1.5 text-sm font-medium text-emerald-700 hover:text-emerald-900 transition-colors flex-shrink-0 ml-4">
              See all
              <ArrowRight class="w-3.5 h-3.5" aria-hidden="true" />
            </a>
          </div>
          <div class="flex flex-col lg:flex-row lg:items-center border-t border-emerald-100 divide-y divide-emerald-100 lg:divide-y-0 lg:divide-x lg:divide-emerald-100">
            {articles.map((article) => (
              <a href={article.href} class="group flex items-center gap-2 px-5 py-3 lg:px-7 lg:py-3 text-base text-emerald-950 hover:text-emerald-700 hover:bg-emerald-50/60 transition-all flex-1">
                <ChevronRight class="w-4 h-4 text-emerald-300 flex-shrink-0 group-hover:text-emerald-500 group-hover:translate-x-0.5 transition-all" aria-hidden="true" />
                {article.title}
              </a>
            ))}
            <a href="/articles/" class="lg:hidden group flex items-center gap-2 px-5 py-3 text-sm font-medium text-emerald-700 hover:text-emerald-900 hover:bg-emerald-50/60 transition-all">
              <ArrowRight class="w-4 h-4 flex-shrink-0" aria-hidden="true" />
              See all articles
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <FAQSection
    bg="white"
    sectionClass="py-16 lg:py-24 bg-white"
    title="Common Questions"
    subtitle="Answers to what patients most commonly ask before their first visit."
    headingClass="text-3xl sm:text-4xl font-serif font-medium text-emerald-950"
    includeSchema={false}
    items={[
      {
        question: 'Can naturopathic doctors order blood tests?',
        answer: '<p>Yes. As a naturopathic doctor, Dr. MacLeod can order a comprehensive range of blood and laboratory tests through private labs. This includes thyroid panels, hormone levels, nutrient status, inflammatory markers and more. Private testing often means broader panels and faster turnaround compared to the public system, giving us a clear picture of your health.</p>',
      },
      {
        question: 'Is naturopathic medicine covered by insurance?',
        answer: '<p>Yes, most extended health insurance plans cover naturopathic visits. We offer direct billing for many major insurers to make the process convenient for you.</p>',
      },
      {
        question: 'Do you work alongside my family doctor?',
        answer: "<p>Absolutely. Naturopathic medicine is most effective as part of a coordinated care approach. I regularly share findings and treatment summaries with family doctors and specialists when patients consent. While naturopathic doctors don't have direct referral privileges in Nova Scotia, I actively communicate with other healthcare providers to help facilitate appropriate referrals where needed.</p>",
      },
    ]}
  />

  <!-- Closing CTA -->
  <section class="py-16 lg:py-24 bg-emerald-950">
    <div class="section-shell text-center space-y-6 reveal">
      <h2 class="text-3xl sm:text-4xl font-serif font-medium text-white">Ready to discuss your health and testing needs?</h2>
      <p class="text-emerald-200 text-lg max-w-2xl mx-auto">Book a consultation to discuss your concerns, previous results and the testing or treatment options you would like to explore.</p>
      <div>
        <BookingButton text="Book Online" variant="hero" size="lg" source="bottom-cta" />
      </div>
      <div class="flex flex-wrap justify-center gap-x-4 gap-y-2 text-sm text-emerald-200">
        <span>No referral needed</span>
        <span aria-hidden="true">·</span>
        <span>Direct billing available</span>
      </div>
    </div>
  </section>

  <!-- FAQ Schema for AI discoverability -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
