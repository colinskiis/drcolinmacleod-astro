---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CTAButton from '../components/CTAButton.astro';
import ArticleSearch from '../components/ArticleSearch.astro';
import { getCollection } from 'astro:content';
import { articleTopicFilters, articleTopics, getArticleTopics } from '../lib/articleTopics';
import { toArticleSearchIndex } from '../lib/articleSearchIndex';
import { readingTime } from '../lib/readingTime';

const topicLabel = (article: (typeof allArticles)[number]) => {
  const id = getArticleTopics(article)[0];
  return articleTopics.find((t) => t.id === id)?.label;
};

const allArticles = await getCollection('articles', ({ data }) => {
  return data.draft !== true;
});
const sortedArticles = allArticles.sort((a, b) =>
  new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

const articleSearchIndex = toArticleSearchIndex(sortedArticles);

const topicCounts = articleTopicFilters.reduce((counts, topic) => {
  counts[topic.id] = topic.id === 'all'
    ? sortedArticles.length
    : sortedArticles.filter((article) => getArticleTopics(article).includes(topic.id)).length;
  return counts;
}, {} as Record<string, number>);

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Health Articles & Resources",
  "description": "Evidence-based articles on natural health, nutrition, herbal medicine and naturopathic treatments by Dr. Colin MacLeod, ND in Halifax, Nova Scotia.",
  "url": "https://drcolinmacleod.com/articles/",
  "hasPart": articleTopics.map((topic) => ({
    "@type": "CollectionPage",
    "name": topic.title,
    "url": `https://drcolinmacleod.com/articles/${topic.id}/`
  }))
};
---

<BaseLayout
  title="Health Articles & Resources"
  description="Evidence-based articles on natural health, nutrition, herbal medicine and naturopathic treatments by Dr. Colin MacLeod, ND in Halifax, Nova Scotia."
  focusKeyword="naturopathic health articles Halifax"
  customSchemas={[collectionSchema]}
>
  <HeroSection title="Articles" centered compact>
    <p>Evidence-based articles on natural health, nutrition and treatment approaches</p>
  </HeroSection>

  <section class="py-16 lg:py-24 bg-white">
    <div class="section-shell">
      <div class="max-w-4xl mx-auto reveal">
        <div class="mb-8 sm:mb-10">
          <nav class="grid grid-cols-2 gap-2 sm:flex sm:flex-wrap sm:gap-3" aria-label="Browse articles by topic">
            {articleTopicFilters.map((topic) => (
              <a
                href={topic.id === 'all' ? '/articles/' : `/articles/${topic.id}/`}
                aria-current={topic.id === 'all' ? 'page' : undefined}
                class:list={[
                  'rounded-full border px-3 py-2 text-sm font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 sm:px-4',
                  topic.id === 'all'
                    ? 'border-emerald-900 bg-emerald-900 text-white'
                    : 'border-emerald-100 bg-white text-emerald-900 hover:border-emerald-300 hover:bg-emerald-50'
                ]}
              >
                <span>{topic.label}</span>
                <span class:list={[
                  'ml-1 text-xs',
                  topic.id === 'all' ? 'text-white/70' : 'text-slate-400'
                ]} aria-hidden="true">{topicCounts[topic.id]}</span>
              </a>
            ))}
          </nav>
        </div>

        <ArticleSearch articles={articleSearchIndex} />

        <div id="article-list">
        {sortedArticles.map((article) => (
          <a
            href={`/articles/${article.slug}`}
            data-article-search-item
            data-article-slug={article.slug}
            class="group flex items-center gap-4 py-5 border-b border-slate-100 last:border-0 -mx-4 px-4 rounded-lg hover:bg-emerald-50/50 transition-colors focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-inset"
          >
            {article.data.heroImage && (
              <div class="hidden sm:block w-24 h-16 rounded-lg overflow-hidden flex-shrink-0 bg-emerald-50">
                <img
                  src={article.data.heroImage}
                  alt=""
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  width="96"
                  height="64"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            )}
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-x-2 text-xs text-slate-500 mb-1">
                <time>
                  {new Date(article.data.publishDate).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric'
                  })}
                </time>
                <span aria-hidden="true">&middot;</span>
                <span>{readingTime(article.body)} min read</span>
                {topicLabel(article) && (
                  <>
                    <span aria-hidden="true">&middot;</span>
                    <span class="text-emerald-700 font-medium">{topicLabel(article)}</span>
                  </>
                )}
              </div>
              <h2 class="article-search-title text-lg sm:text-xl font-serif font-medium text-slate-900 group-hover:text-emerald-700 transition-colors leading-snug">
                {article.data.title}
              </h2>
              <p class="article-search-description text-sm text-slate-500 mt-1 line-clamp-2">{article.data.description}</p>
            </div>
            <svg class="w-5 h-5 text-slate-300 group-hover:text-emerald-600 transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))}
        </div>

        <script>
          import '../scripts/articleListSearch.ts';
        </script>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-emerald-950 py-16 lg:py-24">
    <div class="section-shell text-center">
      <h2 class="text-3xl sm:text-4xl font-serif font-medium text-white mb-6">Take Control of Your Health</h2>
      <p class="text-lg sm:text-xl text-white/90 mb-8 max-w-3xl mx-auto leading-relaxed">
        Questions about natural health approaches? Book your appointment to discuss how naturopathic medicine can support your health goals.
      </p>
      <div class="flex justify-center">
        <CTAButton source="articles-cta" />
      </div>
    </div>
  </section>

</BaseLayout>
