---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CTAButton from '../components/CTAButton.astro';
import FAQSection from '../components/FAQSection.astro';
import RelatedCare from '../components/RelatedCare.astro';
import { Check, Info } from '@lucide/astro';

const nutrientMarkers = [
  {
    abbreviation: '25-OH D',
    name: 'Vitamin D',
    description: 'Serum 25-hydroxyvitamin D is the principal blood marker used to assess vitamin D status. Results are interpreted with supplement use, health history and factors affecting bone and mineral metabolism.',
  },
  {
    abbreviation: 'B12',
    name: 'Vitamin B12',
    description: 'Serum vitamin B12 is commonly used as an initial marker. Methylmalonic acid may help clarify some borderline or discordant results, although kidney function can affect its interpretation.',
  },
  {
    abbreviation: 'Iron',
    name: 'Ferritin and iron studies',
    description: 'Ferritin provides information about iron stores. A complete assessment may also include a CBC, serum iron, transferrin or total iron-binding capacity and transferrin saturation.',
  },
  {
    abbreviation: 'B9',
    name: 'Folate',
    description: 'Folate is required for DNA synthesis and normal blood cell production. The usefulness of serum or red-cell folate testing depends on diet, supplementation and the clinical question.',
  },
  {
    abbreviation: 'Mg',
    name: 'Magnesium',
    description: 'Magnesium status is difficult to characterize with a single test because most magnesium is in bone and tissues. Serum, red-cell or urine measurements each have limitations and are interpreted clinically.',
  },
  {
    abbreviation: 'Zn',
    name: 'Zinc',
    description: 'Serum or plasma zinc can contribute to an assessment, but the result varies with collection time, meals, infection, inflammation and other physiological factors.',
  },
];

const reasonsToConsider = [
  'A restricted diet or prolonged low intake of particular food groups',
  'A condition or surgery that may affect digestion or nutrient absorption',
  'Medication use associated with a specific nutrient concern',
  'Unexplained anemia or an abnormal CBC that requires further assessment',
  'Pregnancy planning or another life stage with different nutrient requirements',
  'Monitoring a previously identified deficiency or a prescribed supplement plan',
];

const resultConsiderations = [
  {
    title: 'One marker may not tell the whole story',
    text: 'A nutrient can have several laboratory markers, and each may reflect a different aspect of intake, transport, storage or metabolism.',
  },
  {
    title: 'Health conditions can change a result',
    text: 'Inflammation can increase ferritin, kidney impairment can increase methylmalonic acid and acute illness can affect several nutrient measurements.',
  },
  {
    title: 'Supplements affect interpretation',
    text: 'Recent or ongoing supplementation may raise a measured level without resolving the reason it was low. The dose, form and timing should be reviewed before collection.',
  },
];
---

<BaseLayout
  title="Nutrient Testing in Halifax | Vitamins, Iron & Minerals"
  description="Private nutrient testing in Halifax, including vitamin D, vitamin B12, ferritin, iron studies and selected minerals when clinically appropriate."
  focusKeyword="nutrient testing Halifax"
>
  <HeroSection
    title="Nutrient Testing"
    compact
    image={{ src: '/images/lab-testing/nutrient-status.webp', alt: 'A selection of foods that provide vitamins and minerals', aspect: 'video' }}
  >
    <p>
      Nutrient testing can help assess a suspected deficiency, investigate an abnormal blood count or monitor a known concern. Tests are selected individually and interpreted with diet, supplements, medications and health history.
    </p>
  </HeroSection>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div>
            <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">A clinical, stepwise approach</p>
            <h2 class="mb-5 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">Testing is targeted to a specific concern</h2>
            <p class="text-lg leading-relaxed text-slate-600">
              Symptoms such as fatigue, hair loss or poor concentration are not specific to nutrient deficiency. A focused assessment helps determine whether nutrient testing is reasonable and which markers are most likely to be informative.
            </p>
          </div>

          <ol class="divide-y divide-emerald-100 rounded-2xl border border-emerald-200 bg-emerald-50/60 px-6 sm:px-8">
            <li class="grid grid-cols-[2.5rem_1fr] gap-4 py-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-950 text-sm font-semibold text-white">1</span>
              <div>
                <h3 class="mb-1 font-semibold text-emerald-950">Identify the reason for testing</h3>
                <p class="leading-relaxed text-slate-600">Diet, symptoms, medical history, medications, supplements and previous laboratory results are reviewed first.</p>
              </div>
            </li>
            <li class="grid grid-cols-[2.5rem_1fr] gap-4 py-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-950 text-sm font-semibold text-white">2</span>
              <div>
                <h3 class="mb-1 font-semibold text-emerald-950">Choose appropriate markers</h3>
                <p class="leading-relaxed text-slate-600">A focused set of tests is generally more useful than ordering every available vitamin and mineral measurement.</p>
              </div>
            </li>
            <li class="grid grid-cols-[2.5rem_1fr] gap-4 py-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-950 text-sm font-semibold text-white">3</span>
              <div>
                <h3 class="mb-1 font-semibold text-emerald-950">Interpret and investigate</h3>
                <p class="leading-relaxed text-slate-600">If a deficiency is identified, the result is considered alongside possible causes rather than treated as an isolated number.</p>
              </div>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-emerald-50 py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-6xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Common nutrient markers</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">What the tests measure</h2>
          <p class="text-lg leading-relaxed text-slate-600">Not every marker is needed for every person. The choice depends on the suspected nutrient, the available laboratory methods and whether the result will change the next step.</p>
        </div>

        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {nutrientMarkers.map((marker) => (
            <article class="rounded-2xl border border-emerald-200 bg-white p-7 shadow-sm">
              <div class="mb-6 flex items-center gap-4">
                <span class="flex h-12 min-w-12 items-center justify-center rounded-xl bg-emerald-950 px-2 text-xs font-bold text-white">{marker.abbreviation}</span>
                <h3 class="text-xl font-semibold leading-tight text-emerald-950">{marker.name}</h3>
              </div>
              <p class="leading-relaxed text-slate-600">{marker.description}</p>
            </article>
          ))}
        </div>

        <div class="mt-6 flex gap-3 rounded-xl bg-white p-5 text-sm leading-relaxed text-slate-600 ring-1 ring-emerald-200">
          <Info class="mt-0.5 h-5 w-5 flex-none text-emerald-700" aria-hidden="true" />
          <p>Laboratory reference intervals and clinical decision thresholds vary by marker, method and circumstance. Results are not assigned a separate universal “optimal” range.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Understanding results</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">Nutrient markers have important limitations</h2>
          <p class="text-lg leading-relaxed text-slate-600">The result must be interpreted in the setting in which it was collected. An apparently low or high value may require confirmation, related tests or assessment of another health condition.</p>
        </div>

        <div class="overflow-hidden rounded-2xl border border-emerald-200">
          {resultConsiderations.map((item, index) => (
            <div class:list={['grid gap-2 p-6 sm:grid-cols-[0.8fr_1.2fr] sm:gap-8 sm:p-7', index !== resultConsiderations.length - 1 && 'border-b border-emerald-100']}>
              <p class="font-semibold text-emerald-950">{item.title}</p>
              <p class="leading-relaxed text-slate-600">{item.text}</p>
            </div>
          ))}
        </div>

        <div class="mt-6 rounded-xl bg-amber-50 p-5 text-sm leading-relaxed text-amber-950 ring-1 ring-amber-200">
          Iron supplementation can be harmful when it is not indicated, and high doses of some nutrients can cause toxicity or interact with medications. Supplements should be included in the medication review and should not be stopped or changed solely to prepare for testing unless specifically instructed.
        </div>
      </div>
    </div>
  </section>

  <section class="bg-emerald-950 py-16 lg:py-20">
    <div class="section-shell">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
        <div>
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-300">Selecting tests</p>
          <h2 class="mb-5 text-3xl font-medium text-white sm:text-4xl font-serif">When nutrient testing may be considered</h2>
          <p class="leading-relaxed text-emerald-50/85">These circumstances can influence the choice of tests. They do not establish a deficiency on their own or mean that a broad nutrient panel is required.</p>
        </div>
        <ul class="grid gap-3 sm:grid-cols-2">
          {reasonsToConsider.map((reason) => (
            <li class="flex gap-3 rounded-xl border border-white/15 bg-white/10 p-4 text-sm leading-relaxed text-white">
              <Check class="mt-0.5 h-5 w-5 flex-none text-emerald-300" aria-hidden="true" />
              <span>{reason}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 max-w-3xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Private testing in Nova Scotia</p>
          <h2 class="mb-4 text-3xl font-medium text-emerald-950 sm:text-4xl font-serif">How the testing process works</h2>
          <p class="text-lg leading-relaxed text-slate-600">A family doctor or specialist referral is not required. Testing is selected and reviewed through the naturopathic appointment process.</p>
        </div>

        <ol class="grid gap-5 md:grid-cols-3">
          <li class="rounded-2xl border border-emerald-200 p-6">
            <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 font-semibold text-emerald-800">1</span>
            <h3 class="mb-2 text-lg font-semibold text-emerald-950">Clinical review</h3>
            <p class="text-sm leading-relaxed text-slate-600">Diet, symptoms, health history, supplements, medications and previous results are reviewed.</p>
          </li>
          <li class="rounded-2xl border border-emerald-200 p-6">
            <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 font-semibold text-emerald-800">2</span>
            <h3 class="mb-2 text-lg font-semibold text-emerald-950">Requisition and collection</h3>
            <p class="text-sm leading-relaxed text-slate-600">A private laboratory requisition is provided. Costs and any preparation instructions are confirmed before collection.</p>
          </li>
          <li class="rounded-2xl border border-emerald-200 p-6">
            <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 font-semibold text-emerald-800">3</span>
            <h3 class="mb-2 text-lg font-semibold text-emerald-950">Results and follow-up</h3>
            <p class="text-sm leading-relaxed text-slate-600">Results are reviewed with their limitations. Follow-up may include investigating a cause, treatment or repeat testing.</p>
          </li>
        </ol>

        <div class="mt-8 rounded-2xl bg-emerald-50 p-6">
          <p class="text-sm leading-relaxed text-slate-600">Laboratory testing ordered through a naturopathic doctor is not covered by MSI. Some extended health plans may cover naturopathic appointments, but laboratory coverage varies.</p>
        </div>
      </div>
    </div>
  </section>

  <RelatedCare
    title="Related Testing"
    hubHref="/lab-testing/"
    hubLabel="Lab Testing"
    links={[
      { title: 'Wellness Blood Work', href: '/wellness-blood-work/' },
      { title: 'Complete Thyroid Panel', href: '/thyroid-testing/' },
      { title: 'Hormone Testing', href: '/hormone-testing/' },
    ]}
  />

  <FAQSection bg="white" items={[
    {
      question: "Do I need a doctor's requisition for nutrient testing?",
      answer: '<p>You do not need a family doctor or specialist referral. After reviewing the reason for testing, I can provide a private laboratory requisition for the markers that are appropriate.</p>',
    },
    {
      question: 'Do I need a comprehensive nutrient panel?',
      answer: '<p>Usually not. Tests are chosen to address a particular concern, previous finding or risk factor. Broad panels can add cost and produce results that are difficult to interpret without a clear clinical question.</p>',
    },
    {
      question: 'How are nutrient results interpreted?',
      answer: "<p>Results are compared with the reporting laboratory's intervals and interpreted with symptoms, diet, supplements, medications and related markers. Universal functional or “optimal” ranges are not applied independently of that context.</p>",
    },
    {
      question: 'Do I need to fast or stop supplements before testing?',
      answer: '<p>Preparation depends on the markers selected. Food intake and recent supplements can affect some tests, so specific instructions will be provided. Do not stop prescribed medication or change supplements unless you have been instructed to do so.</p>',
    },
    {
      question: 'When should an abnormal nutrient test be repeated?',
      answer: '<p>The timing depends on the nutrient, the degree of abnormality, the suspected cause and any treatment provided. Repeat testing is used when it is likely to confirm a finding or change management, rather than at a fixed interval for every person.</p>',
    },
  ]} />

  <section class="bg-emerald-950 py-16 lg:py-24">
    <div class="section-shell">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="mb-6 text-3xl font-medium text-white sm:text-4xl font-serif">Discuss Whether Nutrient Testing Is Appropriate</h2>
        <p class="mb-8 text-lg leading-relaxed text-white/90">Book an initial consultation to review your concerns, previous results and which nutrient markers, if any, would provide useful information.</p>
        <CTAButton source="nutrient-testing-cta" />
      </div>
    </div>
  </section>
</BaseLayout>
