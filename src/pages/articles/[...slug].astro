---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import FAQSection from '../../components/FAQSection.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import { readingTime } from '../../lib/readingTime';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => data.draft !== true);
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: article,
  }));
}

type Props = CollectionEntry<'articles'>;

const article = Astro.props;
const { Content } = await article.render();
const minutes = readingTime(article.body);

const heroImage = article.data.heroImage;
const heroWebp =
  heroImage?.replace(/\.(png|jpe?g)$/i, '.webp') ?? null;
const heroUsesWebp = heroImage?.endsWith('.webp') ?? false;

// SEO preparation
const seoTitle = article.data.seo?.title || article.data.title;
const seoDescription = article.data.seo?.description || article.data.description;
const focusKeyword = article.data.seo?.focusKeyword || '';

// Format dates
const publishedDate = new Date(article.data.publishDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const modifiedDate = article.data.modifiedDate
  ? new Date(article.data.modifiedDate).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    })
  : null;

// BreadcrumbList schema for AI discoverability
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://drcolinmacleod.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Articles",
      "item": "https://drcolinmacleod.com/articles/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": article.data.title,
      "item": `https://drcolinmacleod.com/articles/${article.slug}`
    }
  ]
};

// Article schema for Google rich results
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.data.title,
  "description": article.data.description,
  "author": {
    "@type": "Person",
    "name": article.data.author,
    "url": "https://drcolinmacleod.com/about/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dr. Colin MacLeod ND",
    "logo": {
      "@type": "ImageObject",
      "url": "https://drcolinmacleod.com/favicon.svg"
    }
  },
  "datePublished": article.data.publishDate,
  "dateModified": article.data.modifiedDate || article.data.publishDate,
  "image": article.data.heroImage ? `https://drcolinmacleod.com${article.data.heroImage}` : "https://drcolinmacleod.com/images/reference/home-background.webp",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://drcolinmacleod.com/articles/${article.slug}`
  }
};
---

<BaseLayout 
  title={seoTitle}
  description={seoDescription}
  focusKeyword={focusKeyword}
>
  <!-- Reading Progress Bar -->
  <div id="reading-progress" class="fixed top-0 left-0 h-[3px] bg-emerald-500 z-50 transition-[width] duration-75 ease-out" style="width: 0%"></div>

  <!-- Article Header -->
  <article class="py-16 lg:py-24 bg-white">
    <div class="section-shell">
      <div class="max-w-4xl mx-auto">
        
        <!-- Breadcrumbs -->
        <nav class="flex items-center space-x-2 text-sm mb-8">
          <a href="/" class="text-emerald-800 hover:text-emerald-900 font-medium">Home</a>
          <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
          <a href="/articles/" class="text-emerald-800 hover:text-emerald-900 font-medium">Articles</a>
          <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
          <span class="text-slate-500 truncate min-w-0">{article.data.title}</span>
        </nav>

        <!-- Article Header -->
        <header class="mb-12 max-w-[70ch]">
          <h1 class="text-4xl sm:text-5xl font-serif font-bold text-emerald-950 mb-6 leading-tight tracking-tight">
            {article.data.title}
          </h1>
          
          <p class="text-xl text-slate-600 mb-6 leading-relaxed">
            {article.data.description}
          </p>

          <!-- Author Byline -->
          <div class="flex items-center gap-3 pt-6 border-t border-slate-200">
            <img
              src="/images/general/colin-hero.webp"
              alt="Dr. Colin MacLeod ND"
              class="w-10 h-10 rounded-full object-cover object-top flex-shrink-0"
              width="40"
              height="40"
              loading="lazy"
              decoding="async"
            />
            <div>
              <span class="text-sm font-semibold text-slate-900">{article.data.author}</span>
              <div class="flex flex-wrap items-center gap-x-3 text-xs text-slate-500 mt-0.5">
                <time>{publishedDate}</time>
                {modifiedDate && <span>Updated {modifiedDate}</span>}
                <span>{minutes} min read</span>
              </div>
            </div>
          </div>
        </header>

        <!-- Hero Image -->
        {heroImage && (
          <div class="mb-12 -mx-5 sm:mx-0 aspect-[2/1] overflow-hidden sm:rounded-xl shadow-lg">
            <picture>
              {heroWebp && !heroUsesWebp && (
                <source srcset={heroWebp} type="image/webp" />
              )}
              <img
                src={heroImage}
                alt=""
                class="w-full h-full object-cover"
                width="1536"
                height="1024"
                loading="eager"
                fetchpriority="high"
                decoding="async"
              />
            </picture>
          </div>
        )}

        <!-- Article Content -->
        <div class="prose max-w-[70ch]">
          <Content />
        </div>

        {article.data.faq && article.data.faq.length > 0 && (
          <div class="-mx-5 sm:mx-0 mt-12">
            <FAQSection items={article.data.faq} />
          </div>
        )}

        <!-- Article Footer -->
        <footer class="mt-12 pt-8 border-t border-slate-200">
          
          <!-- Related Articles -->
          <RelatedArticles
            currentSlug={article.slug}
            currentTags={article.data.tags || []}
            currentCategories={article.data.categories}
            limit={5}
          />

          <!-- Author Bio -->
          <div class="bg-emerald-50/50 border border-emerald-100 rounded-2xl p-8 mb-8 mt-8 shadow-sm">
            <div class="flex items-start space-x-4">
              <img
                src="/images/general/colin-hero.webp"
                alt="Dr. Colin MacLeod ND"
                class="w-16 h-16 rounded-full object-cover object-top flex-shrink-0 shadow-lg"
                width="64"
                height="64"
                loading="lazy"
                decoding="async"
              />
              <div class="flex-1">
                <h3 class="text-xl font-serif font-bold text-emerald-950 mb-2">About the Author</h3>
                <p class="text-slate-600 mb-4">
                  Dr. Colin MacLeod ND is a licensed naturopathic doctor in Halifax, Nova Scotia. He has a special interest in blood test interpretation, natural pain solutions, IV therapy and the many benefits of exercise.
                </p>
                <a
                  href="/about/"
                  class="inline-flex items-center text-emerald-800 hover:text-emerald-900 font-medium text-sm"
                >
                  Learn More About Dr. MacLeod
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Back link -->
          <a
            href="/articles/"
            class="inline-flex items-center text-emerald-800 hover:text-emerald-900 font-medium"
          >
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to All Articles
          </a>
        </footer>
      </div>
    </div>
  </article>

  <!-- Related Content CTA -->
  <section class="bg-emerald-950 py-16 lg:py-24">
    <div class="section-shell">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-serif font-bold text-white mb-6">Ready to Explore Natural Health Solutions?</h2>
        <p class="text-lg sm:text-xl text-white/90 mb-8 leading-relaxed">
          Dr. MacLeod can help you understand how naturopathic approaches might benefit your specific health concerns.
        </p>
        <CTAButton source={`article-cta-${article.slug}`} />
      </div>
    </div>
  </section>

  <!-- Reading progress script -->
  <script>
    let progressListener: ((e: Event) => void) | null = null;

    function initReadingProgress() {
      // Remove previous scroll listener if navigating between articles
      if (progressListener) {
        window.removeEventListener('scroll', progressListener);
        progressListener = null;
      }

      const bar = document.getElementById('reading-progress');
      const article = document.querySelector('article') as HTMLElement | null;
      if (!bar || !article) return;
      const progressBar = bar;
      const articleEl = article;

      function updateProgress() {
        const articleTop = articleEl.offsetTop;
        const articleHeight = articleEl.offsetHeight;
        const scrolled = window.scrollY - articleTop;
        const progress = Math.min(Math.max(scrolled / (articleHeight - window.innerHeight), 0), 1);
        progressBar.style.width = (progress * 100) + '%';
      }

      progressListener = updateProgress;
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    }

    document.addEventListener('astro:page-load', initReadingProgress);
  </script>

  <!-- BreadcrumbList Schema for AI discoverability -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Article Schema for Google rich results -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</BaseLayout>
