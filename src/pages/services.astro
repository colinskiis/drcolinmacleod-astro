---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CTAButton from '../components/CTAButton.astro';
import { ChevronRight } from '@lucide/astro';

const featuredServices = [
  {
    title: 'Lab Testing',
    href: '/lab-testing/',
    description: 'Access private blood work, in-office collection and broader testing without a family-doctor requisition.',
    image: '/images/lab-testing/in-office-blood-draw.webp',
    alt: 'Dr. Colin MacLeod performing an in-office blood draw',
  },
  {
    title: 'IV Therapy',
    href: '/iv-therapy/',
    description: 'Individualized intravenous nutrient therapy with clinical screening, preparation and monitoring.',
    image: '/images/treatments/iv-patient-woman.webp',
    alt: 'Patient receiving IV nutrient therapy in the clinic',
  },
  {
    title: 'Prolotherapy',
    href: '/prolotherapy/',
    description: 'Dextrose injection treatment used in the practice for selected joint, tendon and ligament concerns.',
    image: '/images/treatments/prolotherapy-knee-injection.webp',
    alt: 'Dr. Colin MacLeod performing a prolotherapy knee injection',
  },
];

const primaryService = featuredServices[0];
const secondaryServices = featuredServices.slice(1);

const serviceGroups = [
  {
    title: 'Natural Healthcare',
    items: [
      { label: 'Lab Testing', href: '/lab-testing/' },
      { label: 'Clinical Nutrition', href: '/clinical-nutrition/' },
      { label: 'Herbal Medicine', href: '/herbal-medicine/' },
      { label: 'Acupuncture', href: '/acupuncture/' },
      { label: 'Sports Medicine', href: '/sports-medicine/' },
    ],
  },
  {
    title: 'IV Therapy',
    items: [
      { label: 'Myers Cocktail', href: '/myers-cocktail-intravenous-nutrients/' },
      { label: 'NAD+ Therapy', href: '/nad-therapy/' },
      { label: 'Chelation Therapy', href: '/chelation-therapy/' },
      { label: 'IV Vitamin C', href: '/iv-vitamin-c/' },
      { label: 'Glutathione', href: '/glutathione/' },
    ],
  },
  {
    title: 'Pain & Injection',
    items: [
      { label: 'Prolotherapy', href: '/prolotherapy/' },
      { label: 'Neural Prolotherapy', href: '/neural-prolotherapy-pain/' },
      { label: 'Microcurrent Therapy', href: '/microcurrent-therapy/' },
    ],
  },
];

const pricingGroups = [
  {
    title: 'Consultations',
    rows: [
      ['Initial Visit', '$200'],
      ['Follow-up Visit', '$100'],
    ],
  },
  {
    title: 'Treatments',
    rows: [
      ['IV Therapy', '$130'],
      ['Injection Treatments', '$110'],
      ['Acupuncture', '$75'],
      ['Vitamin B12 Injection', '$35'],
    ],
  },
  {
    title: 'Specialized IV Treatments',
    rows: [
      ['NAD+ IV Therapy', '$190'],
      ['Myers Cocktail', '$130'],
      ['Chelation Therapy', '$130'],
    ],
  },
  {
    title: 'Combined Visits',
    rows: [
      ['Initial Visit + IV Treatment', '$260'],
      ['Initial Visit + Prolotherapy', '$260'],
    ],
  },
];
---

<BaseLayout
  title="Services"
  description="Complete naturopathic healthcare services including IV therapy, prolotherapy, acupuncture, clinical nutrition and specialized treatments for chronic conditions in Halifax, Nova Scotia."
  focusKeyword="naturopathic services Halifax"
>
  <HeroSection title="Naturopathic Services" centered compact>
    Private testing, clinical consultations and in-office treatments selected according to your health history, priorities and goals.
  </HeroSection>

  <!-- Featured Service Areas -->
  <section class="py-14 lg:py-20 bg-white">
    <div class="section-shell">
      <div class="mb-10 max-w-3xl reveal">
        <p class="pill mb-4">Major Service Areas</p>
        <h2 class="text-3xl sm:text-4xl font-serif font-medium text-emerald-950 mb-4">Find the right starting point</h2>
        <p class="text-lg text-slate-600">
          Laboratory testing is the most common reason patients contact the practice. IV therapy and prolotherapy are also available for selected patients after an appropriate assessment.
        </p>
      </div>

      <div class="space-y-6 reveal reveal-delay-100">
        <a
          href={primaryService.href}
          class="group grid overflow-hidden rounded-3xl border border-emerald-100 bg-emerald-50 shadow-xl shadow-emerald-900/5 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-2xl hover:shadow-emerald-900/10 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 sm:grid-cols-[1.1fr_0.9fr]"
        >
          <div class="aspect-[16/10] overflow-hidden sm:min-h-[23rem] sm:aspect-auto">
            <img
              src={primaryService.image}
              alt={primaryService.alt}
              class="h-full w-full object-cover object-[center_20%] transition-transform duration-500 group-hover:scale-[1.02] sm:object-center"
              width="800"
              height="600"
              loading="lazy"
            />
          </div>
          <div class="flex flex-col justify-center p-7 sm:p-10 lg:p-12">
            <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700">Private Laboratory Access</p>
            <h3 class="mb-4 text-3xl font-serif font-medium text-emerald-950 transition-colors group-hover:text-emerald-700 sm:text-4xl">{primaryService.title}</h3>
            <p class="mb-6 text-base leading-relaxed text-slate-600 sm:text-lg">{primaryService.description}</p>
            <span class="inline-flex items-center gap-1.5 font-semibold text-emerald-800">
              Explore Lab Testing
              <ChevronRight class="h-4 w-4 transition-transform group-hover:translate-x-0.5" aria-hidden="true" />
            </span>
          </div>
        </a>

        <div class="grid gap-4 sm:grid-cols-2 sm:gap-6">
          {secondaryServices.map(({ title, href, description, image, alt }) => (
            <a
              href={href}
              class="group grid min-h-36 grid-cols-[8rem_1fr] overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-md shadow-emerald-900/5 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 sm:block"
            >
              <div class="overflow-hidden sm:aspect-[16/9]">
                <img
                  src={image}
                  alt={alt}
                  class:list={[
                    'h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]',
                    title === 'Prolotherapy' ? 'object-top' : 'object-center',
                  ]}
                  width="800"
                  height="450"
                  loading="lazy"
                />
              </div>
              <div class="flex flex-col justify-center p-5 sm:p-7">
                <h3 class="mb-2 text-xl font-serif font-medium text-emerald-950 transition-colors group-hover:text-emerald-700 sm:text-2xl">{title}</h3>
                <p class="hidden leading-relaxed text-slate-600 sm:block">{description}</p>
                <span class="mt-2 inline-flex items-center gap-1 text-sm font-semibold text-emerald-700 sm:mt-4">
                  View service
                  <ChevronRight class="h-4 w-4 transition-transform group-hover:translate-x-0.5" aria-hidden="true" />
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Service Directory -->
  <section class="py-14 lg:py-20 bg-[#f7f7f5]">
    <div class="section-shell">
      <div class="mb-8 text-center reveal">
        <h2 class="text-2xl sm:text-3xl font-serif font-medium text-emerald-950 mb-2">All Services</h2>
        <p class="text-slate-600">Browse our complete list of treatments and services</p>
      </div>

      <div class="overflow-hidden rounded-2xl border border-emerald-100 bg-white shadow-sm reveal reveal-delay-100">
        <div class="grid divide-y divide-emerald-100 md:grid-cols-3 md:divide-x md:divide-y-0">
          {serviceGroups.map((group) => (
            <div class="p-6">
              <h3 class="mb-4 text-base font-serif font-medium text-emerald-950">{group.title}</h3>
              <ul class="space-y-1">
                {group.items.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class="group flex items-center justify-between rounded-lg px-2 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-emerald-50 hover:text-emerald-800 focus:outline-none focus:ring-2 focus:ring-emerald-500"
                    >
                      <span>{item.label}</span>
                      <ChevronRight class="h-4 w-4 text-emerald-400 transition-transform group-hover:translate-x-0.5 group-hover:text-emerald-600" aria-hidden="true" />
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section id="pricing" class="py-14 sm:py-16 lg:py-20 bg-white">
    <div class="section-shell">
      <div class="text-center mb-10 reveal">
        <h2 class="text-3xl sm:text-4xl font-serif font-medium text-emerald-950 mb-4">Service Pricing</h2>
        <p class="text-lg text-slate-600 max-w-3xl mx-auto">
          Most services are eligible for insurance direct-billing
        </p>
      </div>

      <div class="mx-auto max-w-4xl overflow-hidden rounded-2xl border border-emerald-100 bg-white shadow-sm reveal reveal-delay-100">
        {pricingGroups.map((group, groupIndex) => (
          <div class:list={[
            'grid md:grid-cols-[220px_1fr]',
            groupIndex !== pricingGroups.length - 1 && 'border-b border-emerald-100',
          ]}>
            <div class="bg-emerald-50/70 px-5 py-4 md:px-6">
              <h3 class="font-serif font-medium text-emerald-950">{group.title}</h3>
            </div>
            <ul class="divide-y divide-slate-100">
              {group.rows.map(([label, price]) => (
                <li class="flex items-center justify-between gap-6 px-5 py-4 md:px-6">
                  <span class="text-slate-700">{label}</span>
                  <span class="font-semibold text-emerald-950">{price}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 lg:py-24 bg-emerald-950">
    <div class="section-shell">
      <div class="text-center max-w-3xl mx-auto reveal">
        <h2 class="text-3xl sm:text-4xl font-serif font-medium text-white mb-6">Not Sure Where to Start?</h2>
        <p class="text-lg text-white/80 mb-8">
          Book an initial consultation to discuss your health concerns and determine which services are right for you.
        </p>
        <CTAButton source="services-cta" />
      </div>
    </div>
  </section>
</BaseLayout>
