---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CTAButton from '../components/CTAButton.astro';
import { Activity, ChevronRight, Droplets, FlaskConical, Utensils } from '@lucide/astro';

const featuredServices = [
  {
    title: 'Lab Testing',
    href: '/lab-testing/',
    description: 'Comprehensive diagnostic testing including functional medicine and nutritional assessments.',
    Icon: FlaskConical,
  },
  {
    title: 'IV Therapy',
    href: '/iv-therapy/',
    description: 'Intravenous nutrients including Myers Cocktail, NAD+, chelation, glutathione, vitamin C and more.',
    Icon: Droplets,
  },
  {
    title: 'Sports Medicine',
    href: '/sports-medicine/',
    description: 'Regenerative injection therapies for chronic pain, osteoarthritis, sports injuries and recovery.',
    Icon: Activity,
  },
  {
    title: 'Clinical Nutrition',
    href: '/clinical-nutrition/',
    description: 'Evidence-based dietary and nutritional medicine targeting root causes of chronic health concerns.',
    Icon: Utensils,
  },
];

const serviceGroups = [
  {
    title: 'Natural Healthcare',
    items: [
      { label: 'Lab Testing', href: '/lab-testing/' },
      { label: 'Clinical Nutrition', href: '/clinical-nutrition/' },
      { label: 'Herbal Medicine', href: '/herbal-medicine/' },
      { label: 'Acupuncture', href: '/acupuncture/' },
      { label: 'Sports Medicine', href: '/sports-medicine/' },
    ],
  },
  {
    title: 'IV Therapy',
    items: [
      { label: 'Myers Cocktail', href: '/myers-cocktail-intravenous-nutrients/' },
      { label: 'NAD+ Therapy', href: '/nad-therapy/' },
      { label: 'Chelation Therapy', href: '/chelation-therapy/' },
      { label: 'IV Vitamin C', href: '/iv-vitamin-c/' },
      { label: 'Glutathione', href: '/glutathione/' },
    ],
  },
  {
    title: 'Pain & Injection',
    items: [
      { label: 'Prolotherapy', href: '/prolotherapy/' },
      { label: 'Neural Prolotherapy', href: '/neural-prolotherapy-pain/' },
      { label: 'Microcurrent Therapy', href: '/microcurrent-therapy/' },
    ],
  },
];

const pricingGroups = [
  {
    title: 'Consultations',
    rows: [
      ['Initial Visit', '$200'],
      ['Follow-up Visit', '$100'],
    ],
  },
  {
    title: 'Treatments',
    rows: [
      ['IV Therapy', '$130'],
      ['Injection Treatments', '$110'],
      ['Acupuncture', '$75'],
      ['Vitamin B12 Injection', '$35'],
    ],
  },
  {
    title: 'Specialized IV Treatments',
    rows: [
      ['NAD+ IV Therapy', '$190'],
      ['Myers Cocktail', '$130'],
      ['Chelation Therapy', '$130'],
    ],
  },
  {
    title: 'Combined Visits',
    rows: [
      ['Initial Visit + IV Treatment', '$260'],
      ['Initial Visit + Prolotherapy', '$260'],
    ],
  },
];
---

<BaseLayout
  title="Services"
  description="Complete naturopathic healthcare services including IV therapy, prolotherapy, acupuncture, clinical nutrition and specialized treatments for chronic conditions in Halifax, Nova Scotia."
  focusKeyword="naturopathic services Halifax"
>
  <HeroSection title="Naturopathic Services" centered compact>
    Natural healthcare guided by science and rooted in traditional healing
  </HeroSection>

  <!-- Featured Service Areas -->
  <section class="py-14 lg:py-20 bg-white">
    <div class="section-shell">
      <div class="mb-8 max-w-2xl reveal">
        <p class="pill mb-4">Major Service Areas</p>
        <h2 class="text-3xl sm:text-4xl font-serif font-bold text-emerald-950 mb-4">Find the right starting point</h2>
        <p class="text-lg text-slate-600">
          Start with one of the main service areas below, or browse the full service directory.
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4 reveal reveal-delay-100">
        {featuredServices.map(({ title, href, description, Icon }) => (
          <a
            href={href}
            data-astro-reload
            class="group flex h-full flex-col rounded-2xl border border-emerald-100 bg-white p-5 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:border-emerald-200 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2"
          >
            <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-50 text-emerald-700 ring-1 ring-emerald-100 transition-colors group-hover:bg-emerald-100">
              <Icon class="h-6 w-6" aria-hidden="true" />
            </div>
            <h3 class="mb-3 text-xl font-serif font-semibold text-emerald-950 group-hover:text-emerald-700 transition-colors">{title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{description}</p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-emerald-700">
              View service
              <ChevronRight class="h-4 w-4 transition-transform group-hover:translate-x-0.5" aria-hidden="true" />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Directory -->
  <section class="py-14 lg:py-20 bg-[#f7f7f5]">
    <div class="section-shell">
      <div class="mb-8 text-center reveal">
        <h2 class="text-2xl sm:text-3xl font-serif font-bold text-emerald-950 mb-2">All Services</h2>
        <p class="text-slate-600">Browse our complete list of treatments and services</p>
      </div>

      <div class="overflow-hidden rounded-2xl border border-emerald-100 bg-white shadow-sm reveal reveal-delay-100">
        <div class="grid divide-y divide-emerald-100 md:grid-cols-3 md:divide-x md:divide-y-0">
          {serviceGroups.map((group) => (
            <div class="p-6">
              <h3 class="mb-4 text-base font-serif font-semibold text-emerald-950">{group.title}</h3>
              <ul class="space-y-1">
                {group.items.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class="group flex items-center justify-between rounded-lg px-2 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-emerald-50 hover:text-emerald-800 focus:outline-none focus:ring-2 focus:ring-emerald-500"
                    >
                      <span>{item.label}</span>
                      <ChevronRight class="h-4 w-4 text-emerald-400 transition-transform group-hover:translate-x-0.5 group-hover:text-emerald-600" aria-hidden="true" />
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section id="pricing" class="py-14 sm:py-16 lg:py-20 bg-white">
    <div class="section-shell">
      <div class="text-center mb-10 reveal">
        <h2 class="text-3xl sm:text-4xl font-serif font-bold text-emerald-950 mb-4">Service Pricing</h2>
        <p class="text-lg text-slate-600 max-w-3xl mx-auto">
          Most services are eligible for insurance direct-billing
        </p>
      </div>

      <div class="mx-auto max-w-4xl overflow-hidden rounded-2xl border border-emerald-100 bg-white shadow-sm reveal reveal-delay-100">
        {pricingGroups.map((group, groupIndex) => (
          <div class:list={[
            'grid md:grid-cols-[220px_1fr]',
            groupIndex !== pricingGroups.length - 1 && 'border-b border-emerald-100',
          ]}>
            <div class="bg-emerald-50/70 px-5 py-4 md:px-6">
              <h3 class="font-serif font-semibold text-emerald-950">{group.title}</h3>
            </div>
            <ul class="divide-y divide-slate-100">
              {group.rows.map(([label, price]) => (
                <li class="flex items-center justify-between gap-6 px-5 py-4 md:px-6">
                  <span class="text-slate-700">{label}</span>
                  <span class="font-semibold text-emerald-950">{price}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 lg:py-24 bg-emerald-950">
    <div class="section-shell">
      <div class="text-center max-w-3xl mx-auto reveal">
        <h2 class="text-3xl sm:text-4xl font-serif font-bold text-white mb-6">Not Sure Where to Start?</h2>
        <p class="text-lg text-white/80 mb-8">
          Book an initial consultation to discuss your health concerns and determine which services are right for you.
        </p>
        <CTAButton source="services-cta" />
      </div>
    </div>
  </section>
</BaseLayout>
