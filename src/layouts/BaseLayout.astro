    <script>
      function initMobileMenu() {
        const mobileMenuButton = document.getElementById('mobile-menu-button');
        const mobileMenu = document.getElementById('mobile-menu');
        const menuIcon = document.getElementById('menu-icon');
        const closeIcon = document.getElementById('close-icon');
        const bookBar = document.getElementById('mobile-book-bar');
        const headerNav = document.querySelector('#site-header nav');
        const mainContent = document.getElementById('main-content');
        const footer = document.querySelector('footer');

        const openClasses = ['opacity-0', 'invisible', 'pointer-events-none'];

        function closeMenu() {
          if (mobileMenu) {
            mobileMenu.classList.add(...openClasses);
            mobileMenu.scrollTop = 0;
            // Collapse any expanded accordions so it reopens tidy
            mobileMenu.querySelectorAll('details[open]').forEach((d) => d.removeAttribute('open'));
          }
          menuIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');
          mobileMenuButton?.setAttribute('aria-expanded', 'false');
          mobileMenuButton?.setAttribute('aria-label', 'Open menu');
          document.body.style.overflow = '';
          mainContent?.removeAttribute('inert');
          footer?.removeAttribute('inert');
          if (bookBar) bookBar.style.display = '';
        }

        function openMenu() {
          if (!mobileMenu) return;
          // Anchor the panel just below the header bar and fill to the bottom.
          const navBottom = headerNav ? Math.round(headerNav.getBoundingClientRect().bottom) : 64;
          mobileMenu.style.top = navBottom + 'px';
          mobileMenu.classList.remove(...openClasses);
          menuIcon?.classList.add('hidden');
          closeIcon?.classList.remove('hidden');
          mobileMenuButton?.setAttribute('aria-expanded', 'true');
          mobileMenuButton?.setAttribute('aria-label', 'Close menu');
          document.body.style.overflow = 'hidden';
          mainContent?.setAttribute('inert', '');
          footer?.setAttribute('inert', '');
          if (bookBar) bookBar.style.display = 'none';

          const firstLink = mobileMenu.querySelector<HTMLElement>('a[href]');
          firstLink?.focus();
        }

        // Always start closed (also resets state after View Transitions)
        closeMenu();

        // Only bind listeners once per button element instance.
        // View Transitions replaces the DOM, so we track per-element rather than
        // using a module-level boolean (which would prevent rebinding after navigation).
        if (!mobileMenuButton || mobileMenuButton.dataset.menuBound) return;
        mobileMenuButton.dataset.menuBound = 'true';

        mobileMenuButton.addEventListener('click', () => {
          const isExpanded = mobileMenuButton.getAttribute('aria-expanded') === 'true';
          if (isExpanded) closeMenu();
          else openMenu();
        });

        // Keyboard handling is bound once on document, which survives View
        // Transitions. Resolve live elements each time because page DOM is replaced.
        if (!(window as any).__menuEscBound) {
          (window as any).__menuEscBound = true;
          document.addEventListener('keydown', (e) => {
            const btn = document.getElementById('mobile-menu-button');
            if (!btn || btn.getAttribute('aria-expanded') !== 'true') return;

            if (e.key === 'Escape') {
              btn.click();
              btn.focus();
              return;
            }

            if (e.key === 'Tab') {
              const menu = document.getElementById('mobile-menu');
              if (!menu) return;
              const menuItems = Array.from(menu.querySelectorAll<HTMLElement>(
                'a[href], summary, button, [tabindex]:not([tabindex="-1"])'
              )).filter((item) => item.getClientRects().length > 0);
              const focusable = [btn, ...menuItems];
              const first = focusable[0];
              const last = focusable[focusable.length - 1];

              if (e.shiftKey && document.activeElement === first) {
                e.preventDefault();
                last?.focus();
              } else if (!e.shiftKey && document.activeElement === last) {
                e.preventDefault();
                first?.focus();
              }
            }
          });
        }
      }

      initMobileMenu();
      document.addEventListener('astro:page-load', initMobileMenu);
    </script>

