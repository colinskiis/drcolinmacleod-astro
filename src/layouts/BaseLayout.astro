    <!-- Header Navigation -->
    <header id="site-header" class="fixed inset-x-0 top-0 z-40 bg-emerald-950 shadow-lg">
      <div class="section-shell">
        <nav class="flex items-center justify-between py-4 gap-3 sm:gap-6">
          <!-- Logo with botanical mark -->
          <a href="/" class="flex items-center gap-3 text-white flex-shrink-0 group">
            <!-- CSS Logo Mark - Leaf icon -->
            <div class="relative w-10 h-10 hidden sm:flex items-center justify-center flex-shrink-0">
              <div class="absolute inset-0 rounded-full border-2 border-emerald-400/50 group-hover:border-emerald-300 transition-colors"></div>
              <svg class="w-5 h-5 text-emerald-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 2,11.5 2,13.5C2,15.5 3.75,17.25 3.75,17.25C7,8 17,8 17,8Z"/>
              </svg>
            </div>
            <div class="leading-tight">
              <p class="hidden sm:block text-[10px] uppercase tracking-[0.25em] text-emerald-300/80 font-medium">Naturopathic Doctor</p>
              <p class="text-base sm:text-lg font-semibold text-white tracking-tight">Dr. Colin MacLeod,<span class="text-emerald-300 font-normal"> ND</span></p>
            </div>
          </a>

          <!-- Centered Navigation -->
          <div class="hidden xl:flex items-center justify-center flex-1 gap-4 text-sm font-medium text-white" role="navigation" aria-label="Main navigation">
            <a href="/lab-testing/" data-navigation-source="desktop-main-nav-lab-testing" class={`whitespace-nowrap hover:text-emerald-200 hover:border-emerald-400/50 transition-colors duration-200 pb-1 border-b-2 ${isLabTestingPath ? 'text-emerald-300 border-emerald-400' : 'border-transparent'}`} aria-current={isLabTestingPath ? 'page' : undefined}>Lab Testing</a>
            <a href="/about/" class={`whitespace-nowrap hover:text-emerald-200 hover:border-emerald-400/50 transition-colors duration-200 pb-1 border-b-2 ${currentPath.startsWith('/about') ? 'text-emerald-300 border-emerald-400' : 'border-transparent'}`} aria-current={currentPath.startsWith('/about') ? 'page' : undefined}>About</a>
            <a href="/new-patients/" class={`whitespace-nowrap hover:text-emerald-200 hover:border-emerald-400/50 transition-colors duration-200 pb-1 border-b-2 ${currentPath.startsWith('/new-patients') ? 'text-emerald-300 border-emerald-400' : 'border-transparent'}`} aria-current={currentPath.startsWith('/new-patients') ? 'page' : undefined}>New Patients</a>
            <div class="relative group">
              <a
                href="/services/"
                class={`inline-flex items-center gap-1 whitespace-nowrap hover:text-emerald-200 hover:border-emerald-400/50 transition-colors duration-200 pb-1 border-b-2 ${isServicePath ? 'text-emerald-300 border-emerald-400' : 'border-transparent'}`}
                aria-current={isServicePath ? 'page' : undefined}
                aria-haspopup="true"
              >
                Services
                <ChevronDown class="w-3.5 h-3.5 transition-transform group-hover:rotate-180 group-focus-within:rotate-180" aria-hidden="true" />
              </a>
              <div class="invisible pointer-events-none absolute left-1/2 top-full z-50 w-[44rem] max-w-[calc(100vw-3rem)] -translate-x-1/2 pt-4 opacity-0 transition-all duration-150 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:visible group-focus-within:pointer-events-auto group-focus-within:opacity-100">
                <div class="rounded-2xl border border-emerald-800/60 bg-emerald-950/95 p-4 shadow-2xl shadow-emerald-950/40 ring-1 ring-white/10 backdrop-blur">
                  <div class="grid grid-cols-3 gap-3">
                    {serviceMenuGroups.map((group) => (
                      <div>
                        <p class="px-3 pb-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-emerald-300/80">{group.title}</p>
