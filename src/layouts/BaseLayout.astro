const isLabTestingPath = currentPath.startsWith('/lab-testing') || labTestingPaths.includes(currentPath);
const isConditionPath = currentPath.startsWith('/conditions') || conditionPaths.includes(currentPath);
const isServicePath = !isLabTestingPath && (currentPath.startsWith('/services') || servicePaths.includes(currentPath));

