---
import '../styles/global.css';
import manropeWoff2 from '@fontsource/manrope/files/manrope-latin-400-normal.woff2?url';
import playfairWoff2 from '@fontsource/playfair-display/files/playfair-display-latin-500-normal.woff2?url';
import { ClientRouter } from 'astro:transitions';
import Search from '../components/Search.astro';
import MedicalDisclaimer from '../components/MedicalDisclaimer.astro';
import { Calendar, Menu, X, ChevronDown, ChevronRight } from '@lucide/astro';

export interface Props {
  title: string;
  description: string;
  focusKeyword?: string;
  image?: string;
  articleData?: {
    publishDate?: string;
    modifiedDate?: string;
    author?: string;
    tags?: string[];
  };
  customSchemas?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const { title, description, image, articleData, customSchemas = [], noindex = false } = Astro.props;
const titleSuffix = ' | Dr. Colin MacLeod, ND';
const fullTitle = title === 'Home'
  ? 'Dr. Colin MacLeod, ND | Naturopathic Doctor in Halifax'
  : title.length + titleSuffix.length <= 60
    ? `${title}${titleSuffix}`
    : title;
const metaDescription = (() => {
  if (description.length <= 160) return description;

  const excerpt = description.slice(0, 160);
  const sentenceEnd = Math.max(
    excerpt.lastIndexOf('. '),
    excerpt.lastIndexOf('? '),
    excerpt.lastIndexOf('! '),
  );
  if (sentenceEnd >= 100) return excerpt.slice(0, sentenceEnd + 1);

  const wordSafeExcerpt = excerpt
    .slice(0, 157)
    .replace(/\s+\S*$/, '')
    .replace(/[,:;.]$/, '')
    .trimEnd();
  return `${wordSafeExcerpt}…`;
})();
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname;
const analyticsEnabled = ['drcolinmacleod.com', 'www.drcolinmacleod.com'].includes(Astro.url.hostname);
const conditionPaths = [
