---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={metaDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>

    <!-- Marks JS availability so reveal animations only hide content when they can run -->
    <script is:inline>
      document.documentElement.classList.add('js');
      // Mark client-side navigations so entrance animations only play on first load
      document.addEventListener('astro:after-swap', function () {
        document.documentElement.classList.add('astro-navigated');
      }, { once: true });
    </script>

    <!-- Resource hints for faster loading -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preload" href={manropeWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={playfairWoff2} as="font" type="font/woff2" crossorigin />

    <!-- Google Analytics (production only) -->
    {analyticsEnabled && <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-HWHX5T8PEG"></script>}
    {analyticsEnabled && <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      if (!window.__siteAnalyticsInit) {
        window.__siteAnalyticsInit = true;
        gtag('js', new Date());
        // Astro's client router manages page changes. Disable the automatic
        // page_view so the initial load and subsequent navigations use the same
        // explicit event and cannot be counted twice.
        gtag('config', 'G-HWHX5T8PEG', { send_page_view: false });

        document.addEventListener('astro:page-load', function() {
          gtag('event', 'page_view', {
            page_title: document.title,
            page_location: window.location.href,
            page_path: window.location.pathname
          });
        });

        // One delegated listener covers booking buttons and the shared
        // clinical-page navigation across Astro view transitions.
        document.addEventListener('click', function(event) {
          const target = event.target instanceof Element ? event.target : null;
          if (!target) return;

          const bookingLink = target.closest('[data-booking-source]');
          if (bookingLink) {
            gtag('event', 'booking_click', {
              button_source: bookingLink.getAttribute('data-booking-source') || 'unknown',
              page_path: window.location.pathname,
              link_url: bookingLink.getAttribute('href') || ''
            });
            return;
          }

          const tocLink = target.closest('[data-toc-section]');
          if (tocLink) {
            gtag('event', 'toc_click', {
              section_id: tocLink.getAttribute('data-toc-section') || 'unknown',
              page_path: window.location.pathname
            });
            return;
          }

          const relatedLink = target.closest('[data-related-care]');
          if (relatedLink) {
            gtag('event', 'related_care_click', {
              destination_path: relatedLink.getAttribute('href') || '',
              page_path: window.location.pathname
            });
            return;
          }

          const navigationLink = target.closest('[data-navigation-source]');
          if (navigationLink) {
            gtag('event', 'navigation_click', {
              navigation_source: navigationLink.getAttribute('data-navigation-source') || 'unknown',
              destination_path: navigationLink.getAttribute('href') || '',
              page_path: window.location.pathname
            });
          }
        });
      }
    </script>}

    <!-- Canonical URL -->
    {!noindex && <link rel="canonical" href={canonicalUrl} />}
    
    <!-- SEO Meta Tags -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content={articleData ? "article" : "website"} />
    <meta property="og:site_name" content="Dr. Colin MacLeod, ND" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_CA" />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
    
    <meta name="author" content="Dr. Colin MacLeod, ND" />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
    
    <!-- Structured Data: MedicalBusiness -->
    <script is:inline type="application/ld+json" set:html={medicalBusinessSchema} />

    <!-- Structured Data: Person (Practitioner) -->
    <script is:inline type="application/ld+json" set:html={personSchema} />

    <!-- Structured Data: Website and Page -->
    <script is:inline type="application/ld+json" set:html={websiteSchema} />
    <script is:inline type="application/ld+json" set:html={pageSchema} />

    {articleSchema && (
      <script is:inline type="application/ld+json" set:html={articleSchema} />
    )}
    {customSchemaJson.map((schema) => (
      <script is:inline type="application/ld+json" set:html={schema} />
    ))}
    <!-- Fonts loaded via global.css (Manrope, Playfair Display) -->
    <ClientRouter />
  </head>
  <body class="font-sans antialiased bg-[#f7f7f5] text-[#0f1b1a]">
    <!-- Skip to main content link for accessibility -->
    <a
      href="#main-content"
