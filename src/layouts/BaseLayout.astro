    <!-- Scroll-triggered reveal animations & header scroll effect -->
    <script>
      function initRevealObserver() {
        const reveals = document.querySelectorAll('.reveal:not(.visible)');
        if (!reveals.length) return;

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0, rootMargin: '0px 0px 50px 0px' });

        reveals.forEach(el => observer.observe(el));
      }

      let scrollAbortController: AbortController | null = null;
      let mobileBookAbortController: AbortController | null = null;
      let mobileBookObserver: IntersectionObserver | null = null;

      function initMobileBookBar() {
        mobileBookAbortController?.abort();
        mobileBookObserver?.disconnect();
        mobileBookAbortController = new AbortController();

        const bar = document.getElementById('mobile-book-bar');
        if (!bar) return;

        const pageBookingLinks = Array.from(document.querySelectorAll(
          '[data-booking-source]:not([data-booking-source="mobile-sticky"])'
        ));
        const competingElements = Array.from(new Set([
          ...pageBookingLinks.map((link) => link.closest('section') || link),
          document.getElementById('site-footer'),
        ].filter((element): element is Element => element instanceof Element)));
        const visibleCompetingElements = new Set<Element>();
        let observerReady = competingElements.length === 0;

        function updateBookBar() {
          const menuOpen = document.getElementById('mobile-menu-button')?.getAttribute('aria-expanded') === 'true';
          const pastOpeningArea = window.scrollY > Math.max(320, window.innerHeight * 0.55);
          const shouldShow = observerReady && pastOpeningArea && !menuOpen && visibleCompetingElements.size === 0;

          bar?.classList.toggle('opacity-100', shouldShow);
          bar?.classList.toggle('translate-y-0', shouldShow);
          bar?.classList.toggle('pointer-events-auto', shouldShow);
          bar?.classList.toggle('opacity-0', !shouldShow);
          bar?.classList.toggle('translate-y-4', !shouldShow);
          bar?.classList.toggle('pointer-events-none', !shouldShow);
          bar?.setAttribute('aria-hidden', shouldShow ? 'false' : 'true');
          bar?.toggleAttribute('inert', !shouldShow);
        }

        if (competingElements.length) {
          mobileBookObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) visibleCompetingElements.add(entry.target);
              else visibleCompetingElements.delete(entry.target);
            });
            observerReady = true;
            updateBookBar();
          }, { threshold: 0.05 });
          competingElements.forEach((element) => mobileBookObserver?.observe(element));
        }

        window.addEventListener('scroll', updateBookBar, {
          passive: true,
          signal: mobileBookAbortController.signal,
        });
        window.addEventListener('resize', updateBookBar, {
          passive: true,
          signal: mobileBookAbortController.signal,
        });
        document.getElementById('mobile-menu-button')?.addEventListener('click', () => {
          requestAnimationFrame(updateBookBar);
        }, { signal: mobileBookAbortController.signal });
        updateBookBar();
      }

      function initHeaderScroll() {
        // Abort previous listener so it doesn't reference a stale header element
        // after View Transitions replace the DOM.
        scrollAbortController?.abort();
        scrollAbortController = new AbortController();

        const header = document.getElementById('site-header');
        if (!header) return;

        function onScroll() {
          if (!header) return;
          if (window.scrollY > 20) {
            header.classList.add('scrolled');
          } else {
            header.classList.remove('scrolled');
          }
        }

        window.addEventListener('scroll', onScroll, { passive: true, signal: scrollAbortController.signal });
        onScroll();
      }

      initRevealObserver();
      initHeaderScroll();
      initMobileBookBar();
      document.addEventListener('astro:page-load', () => {
        initRevealObserver();
        initHeaderScroll();
        initMobileBookBar();
      });
    </script>

